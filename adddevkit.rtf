package profiling\
\
import (\
    "fmt"\
    "runtime"\
    "sort"\
    "sync"\
    "time"\
)\
\
type CPUProfiler struct \{\
    enabled     bool\
    samples     []*CPUSample\
    interval    time.Duration\
    stopCh      chan bool\
    mu          sync.RWMutex\
    startTime   time.Time\
    totalSamples int64\
\}\
\
type CPUSample struct \{\
    Timestamp   time.Time\
    GoroutineID uint64\
    StackTrace  []string\
    Duration    time.Duration\
    Function    string\
    File        string\
    Line        int\
\}\
\
type CPUProfile struct \{\
    TotalDuration time.Duration\
    Samples       []*CPUSample\
    TopFunctions  []FunctionStats\
\}\
\
type FunctionStats struct \{\
    Name      string\
    Samples   int\
    Percentage float64\
    SelfTime  time.Duration\
    TotalTime time.Duration\
\}\
\
func NewCPUProfiler(interval time.Duration) *CPUProfiler \{\
    if interval == 0 \{\
        interval = 100 * time.Millisecond\
    \}\
    \
    return &CPUProfiler\{\
        enabled:  false,\
        samples:  make([]*CPUSample, 0),\
        interval: interval,\
        stopCh:   make(chan bool),\
    \}\
\}\
\
func (p *CPUProfiler) Start() \{\
    p.mu.Lock()\
    if p.enabled \{\
        p.mu.Unlock()\
        return\
    \}\
    p.enabled = true\
    p.startTime = time.Now()\
    p.samples = make([]*CPUSample, 0)\
    p.mu.Unlock()\
    \
    go p.collector()\
\}\
\
func (p *CPUProfiler) collector() \{\
    ticker := time.NewTicker(p.interval)\
    defer ticker.Stop()\
    \
    for \{\
        select \{\
        case <-ticker.C:\
            p.collectSample()\
        case <-p.stopCh:\
            return\
        \}\
    \}\
\}\
\
func (p *CPUProfiler) collectSample() \{\
    sample := &CPUSample\{\
        Timestamp: time.Now(),\
        StackTrace: getStackTrace(),\
    \}\
    \
    // Get current function info\
    pc, file, line, ok := runtime.Caller(2)\
    if ok \{\
        fn := runtime.FuncForPC(pc)\
        if fn != nil \{\
            sample.Function = fn.Name()\
            sample.File = file\
            sample.Line = line\
        \}\
    \}\
    \
    p.mu.Lock()\
    p.samples = append(p.samples, sample)\
    p.totalSamples++\
    p.mu.Unlock()\
\}\
\
func (p *CPUProfiler) Stop() *CPUProfile \{\
    p.mu.Lock()\
    defer p.mu.Unlock()\
    \
    if !p.enabled \{\
        return nil\
    \}\
    \
    p.enabled = false\
    p.stopCh <- true\
    \
    return p.generateProfile()\
\}\
\
func (p *CPUProfiler) generateProfile() *CPUProfile \{\
    profile := &CPUProfile\{\
        TotalDuration: time.Since(p.startTime),\
        Samples:       p.samples,\
    \}\
    \
    // Aggregate stats by function\
    funcStats := make(map[string]*FunctionStats)\
    \
    for _, sample := range p.samples \{\
        stats, ok := funcStats[sample.Function]\
        if !ok \{\
            stats = &FunctionStats\{Name: sample.Function\}\
            funcStats[sample.Function] = stats\
        \}\
        stats.Samples++\
        stats.Percentage = float64(stats.Samples) / float64(len(p.samples)) * 100\
    \}\
    \
    // Convert to slice and sort\
    profile.TopFunctions = make([]FunctionStats, 0, len(funcStats))\
    for _, stats := range funcStats \{\
        profile.TopFunctions = append(profile.TopFunctions, *stats)\
    \}\
    \
    sort.Slice(profile.TopFunctions, func(i, j int) bool \{\
        return profile.TopFunctions[i].Samples > profile.TopFunctions[j].Samples\
    \})\
    \
    // Keep top 20\
    if len(profile.TopFunctions) > 20 \{\
        profile.TopFunctions = profile.TopFunctions[:20]\
    \}\
    \
    return profile\
\}\
\
func (p *CPUProfiler) Reset() \{\
    p.mu.Lock()\
    defer p.mu.Unlock()\
    \
    p.samples = make([]*CPUSample, 0)\
    p.totalSamples = 0\
    p.startTime = time.Now()\
\}\
\
func getStackTrace() []string \{\
    stack := make([]string, 0)\
    buf := make([]uintptr, 32)\
    n := runtime.Callers(3, buf)\
    frames := runtime.CallersFrames(buf[:n])\
    \
    for \{\
        frame, more := frames.Next()\
        stack = append(stack, fmt.Sprintf("%s:%d %s", frame.File, frame.Line, frame.Function))\
        if !more \{\
            break\
        \}\
    \}\
    \
    return stack\
\}\
\
func (profile *CPUProfile) String() string \{\
    output := fmt.Sprintf("CPU Profile - Total Duration: %v\\n", profile.TotalDuration)\
    output += fmt.Sprintf("Total Samples: %d\\n\\n", len(profile.Samples))\
    output += "Top Functions:\\n"\
    output += "%-40s %10s %10s\\n", "Function", "Samples", "Percentage"\
    output += "%-40s %10s %10s\\n", "--------", "-------", "----------"\
    \
    for _, stats := range profile.TopFunctions \{\
        output += fmt.Sprintf("%-40s %10d %9.2f%%\\n", \
            truncate(stats.Name, 40), stats.Samples, stats.Percentage)\
    \}\
    \
    return output\
\}\
\
func truncate(s string, max int) string \{\
    if len(s) <= max \{\
        return s\
    \}\
    return s[:max-3] + "..."\
\}\
