**`internal/vm/vm.go`** (Extended with GC)\
```go\
package vm\
\
import (\
    "fmt"\
    "reflect"\
    \
    "github.com/navescript/nvs/internal/compiler"\
)\
\
type VM struct \{\
    constants []interface\{\}\
    stack     []*Object\
    sp        int\
    frames    []*Frame\
    globals   []*Object\
    gc        *GarbageCollector\
    builtins  []*Object\
\}\
\
type Frame struct \{\
    cl          *compiler.CompiledFunction\
    ip          int\
    basePointer int\
\}\
\
const StackSize = 2048\
const GlobalsSize = 65536\
\
func New(bytecode *compiler.Bytecode) *VM \{\
    mainFn := &compiler.CompiledFunction\{Instructions: bytecode.Instructions\}\
    mainFrame := &Frame\{cl: mainFn, ip: -1, basePointer: 0\}\
    \
    vm := &VM\{\
        constants: bytecode.Constants,\
        stack:     make([]*Object, StackSize),\
        sp:        0,\
        frames:    []*Frame\{mainFrame\},\
        globals:   make([]*Object, GlobalsSize),\
        gc:        NewGarbageCollector(),\
        builtins:  make([]*Object, len(builtins)),\
    \}\
    \
    // Initialize builtins\
    for i, fn := range builtins \{\
        vm.builtins[i] = vm.gc.Allocate(ObjBuiltin, fn)\
        vm.gc.AddRoot(vm.builtins[i])\
    \}\
    \
    return vm\
\}\
\
func (vm *VM) Run() error \{\
    for vm.currentFrame().ip < len(vm.currentFrame().cl.Instructions)-1 \{\
        vm.currentFrame().ip++\
        ip := vm.currentFrame().ip\
        ins := vm.currentFrame().cl.Instructions\
        op := compiler.Opcode(ins[ip])\
        \
        err := vm.executeOpcode(op, ins, ip)\
        if err != nil \{\
            return err\
        \}\
        \
        // Periodic GC trigger\
        if vm.sp%100 == 0 \{\
            vm.gc.Collect()\
        \}\
    \}\
    return nil\
\}\
\
func (vm *VM) executeOpcode(op compiler.Opcode, ins []byte, ip int) error \{\
    switch op \{\
    case compiler.OpConstant:\
        constIndex := compiler.ReadUint16(ins[ip+1:])\
        constVal := vm.constants[constIndex]\
        \
        var obj *Object\
        switch v := constVal.(type) \{\
        case int64:\
            obj = vm.gc.Allocate(ObjInteger, v)\
        case float64:\
            obj = vm.gc.Allocate(ObjFloat, v)\
        case string:\
            obj = vm.gc.Allocate(ObjString, v)\
        case bool:\
            obj = vm.gc.Allocate(ObjBoolean, v)\
        case *compiler.CompiledFunction:\
            obj = vm.gc.Allocate(ObjFunction, v)\
        default:\
            return fmt.Errorf("unknown constant type: %T", v)\
        \}\
        \
        vm.push(obj)\
        vm.currentFrame().ip += 2\
        \
    case compiler.OpAdd:\
        right := vm.pop()\
        left := vm.pop()\
        \
        if left.Type == ObjInteger && right.Type == ObjInteger \{\
            result := left.Data.(int64) + right.Data.(int64)\
            vm.push(vm.gc.Allocate(ObjInteger, result))\
        \} else if left.Type == ObjFloat && right.Type == ObjFloat \{\
            result := left.Data.(float64) + right.Data.(float64)\
            vm.push(vm.gc.Allocate(ObjFloat, result))\
        \} else if left.Type == ObjString && right.Type == ObjString \{\
            result := left.Data.(string) + right.Data.(string)\
            vm.push(vm.gc.Allocate(ObjString, result))\
        \} else \{\
            return fmt.Errorf("type mismatch: %v + %v", left.Type, right.Type)\
        \}\
        \
    case compiler.OpSub:\
        right := vm.pop()\
        left := vm.pop()\
        \
        if left.Type == ObjInteger && right.Type == ObjInteger \{\
            result := left.Data.(int64) - right.Data.(int64)\
            vm.push(vm.gc.Allocate(ObjInteger, result))\
        \} else if left.Type == ObjFloat && right.Type == ObjFloat \{\
            result := left.Data.(float64) - right.Data.(float64)\
            vm.push(vm.gc.Allocate(ObjFloat, result))\
        \} else \{\
            return fmt.Errorf("type mismatch: %v - %v", left.Type, right.Type)\
        \}\
        \
    case compiler.OpMul:\
        right := vm.pop()\
        left := vm.pop()\
        \
        if left.Type == ObjInteger && right.Type == ObjInteger \{\
            result := left.Data.(int64) * right.Data.(int64)\
            vm.push(vm.gc.Allocate(ObjInteger, result))\
        \} else if left.Type == ObjFloat && right.Type == ObjFloat \{\
            result := left.Data.(float64) * right.Data.(float64)\
            vm.push(vm.gc.Allocate(ObjFloat, result))\
        \} else \{\
            return fmt.Errorf("type mismatch: %v * %v", left.Type, right.Type)\
        \}\
        \
    case compiler.OpDiv:\
        right := vm.pop()\
        left := vm.pop()\
        \
        if left.Type == ObjInteger && right.Type == ObjInteger \{\
            if right.Data.(int64) == 0 \{\
                return fmt.Errorf("division by zero")\
            \}\
            result := left.Data.(int64) / right.Data.(int64)\
            vm.push(vm.gc.Allocate(ObjInteger, result))\
        \} else if left.Type == ObjFloat && right.Type == ObjFloat \{\
            result := left.Data.(float64) / right.Data.(float64)\
            vm.push(vm.gc.Allocate(ObjFloat, result))\
        \} else \{\
            return fmt.Errorf("type mismatch: %v / %v", left.Type, right.Type)\
        \}\
        \
    case compiler.OpTrue:\
        vm.push(vm.gc.Allocate(ObjBoolean, true))\
        \
    case compiler.OpFalse:\
        vm.push(vm.gc.Allocate(ObjBoolean, false))\
        \
    case compiler.OpEqual:\
        right := vm.pop()\
        left := vm.pop()\
        vm.push(vm.gc.Allocate(ObjBoolean, reflect.DeepEqual(left.Data, right.Data)))\
        \
    case compiler.OpNotEqual:\
        right := vm.pop()\
        left := vm.pop()\
        vm.push(vm.gc.Allocate(ObjBoolean, !reflect.DeepEqual(left.Data, right.Data)))\
        \
    case compiler.OpGreaterThan:\
        right := vm.pop()\
        left := vm.pop()\
        \
        if left.Type == ObjInteger && right.Type == ObjInteger \{\
            vm.push(vm.gc.Allocate(ObjBoolean, left.Data.(int64) > right.Data.(int64)))\
        \} else if left.Type == ObjFloat && right.Type == ObjFloat \{\
            vm.push(vm.gc.Allocate(ObjBoolean, left.Data.(float64) > right.Data.(float64)))\
        \} else \{\
            return fmt.Errorf("type mismatch: %v > %v", left.Type, right.Type)\
        \}\
        \
    case compiler.OpPop:\
        vm.pop()\
        \
    case compiler.OpSetGlobal:\
        globalIndex := compiler.ReadUint16(ins[ip+1:])\
        vm.globals[globalIndex] = vm.pop()\
        vm.gc.AddRoot(vm.globals[globalIndex])\
        vm.currentFrame().ip += 2\
        \
    case compiler.OpGetGlobal:\
        globalIndex := compiler.ReadUint16(ins[ip+1:])\
        vm.push(vm.globals[globalIndex])\
        vm.currentFrame().ip += 2\
        \
    case compiler.OpSetLocal:\
        localIndex := compiler.ReadUint16(ins[ip+1:])\
        frame := vm.currentFrame()\
        vm.stack[frame.basePointer+int(localIndex)] = vm.pop()\
        vm.currentFrame().ip += 2\
        \
    case compiler.OpGetLocal:\
        localIndex := compiler.ReadUint16(ins[ip+1:])\
        frame := vm.currentFrame()\
        vm.push(vm.stack[frame.basePointer+int(localIndex)])\
        vm.currentFrame().ip += 2\
        \
    case compiler.OpArray:\
        numElements := compiler.ReadUint16(ins[ip+1:])\
        array := make([]*Object, numElements)\
        for i := int(numElements - 1); i >= 0; i-- \{\
            array[i] = vm.pop()\
        \}\
        obj := vm.gc.Allocate(ObjArray, array)\
        vm.push(obj)\
        vm.currentFrame().ip += 2\
        \
    case compiler.OpHash:\
        numPairs := compiler.ReadUint16(ins[ip+1:])\
        hash := make(map[string]*Object)\
        for i := 0; i < int(numPairs); i++ \{\
            key := vm.pop()\
            value := vm.pop()\
            hash[fmt.Sprintf("%v", key.Data)] = value\
        \}\
        obj := vm.gc.Allocate(ObjHash, hash)\
        vm.push(obj)\
        vm.currentFrame().ip += 2\
        \
    case compiler.OpIndex:\
        index := vm.pop()\
        left := vm.pop()\
        \
        if left.Type == ObjArray \{\
            array := left.Data.([]*Object)\
            idx := int(index.Data.(int64))\
            if idx < 0 || idx >= len(array) \{\
                return fmt.Errorf("array index out of bounds: %d", idx)\
            \}\
            vm.push(array[idx])\
        \} else if left.Type == ObjHash \{\
            hash := left.Data.(map[string]*Object)\
            key := fmt.Sprintf("%v", index.Data)\
            if val, ok := hash[key]; ok \{\
                vm.push(val)\
            \} else \{\
                vm.push(vm.gc.Allocate(ObjBoolean, false))\
            \}\
        \} else \{\
            return fmt.Errorf("index operator not supported on %v", left.Type)\
        \}\
        \
    case compiler.OpCall:\
        numArgs := compiler.ReadUint16(ins[ip+1:])\
        return vm.executeCall(int(numArgs))\
        \
    case compiler.OpReturnValue:\
        returnValue := vm.pop()\
        \
        frame := vm.currentFrame()\
        vm.popFrame()\
        \
        if len(vm.frames) == 0 \{\
            // Main function return\
            return nil\
        \}\
        \
        vm.stack[vm.sp] = returnValue\
        vm.sp++\
        \
    case compiler.OpReturn:\
        vm.popFrame()\
        \
    case compiler.OpGetBuiltin:\
        builtinIndex := compiler.ReadUint16(ins[ip+1:])\
        builtin := vm.builtins[builtinIndex]\
        vm.push(builtin)\
        vm.currentFrame().ip += 2\
        \
    default:\
        return fmt.Errorf("unknown opcode: %d", op)\
    \}\
    \
    return nil\
\}\
\
func (vm *VM) executeCall(numArgs int) error \{\
    callee := vm.stack[vm.sp-1-numArgs]\
    \
    switch callee.Type \{\
    case ObjFunction:\
        fn := callee.Data.(*compiler.CompiledFunction)\
        frame := &Frame\{\
            cl:          fn,\
            ip:          -1,\
            basePointer: vm.sp - numArgs,\
        \}\
        vm.pushFrame(frame)\
        vm.sp = frame.basePointer + fn.NumLocals\
        \
    case ObjBuiltin:\
        builtinFn := callee.Data.(func(...interface\{\}) interface\{\})\
        args := make([]interface\{\}, numArgs)\
        for i := 0; i < numArgs; i++ \{\
            args[i] = vm.stack[vm.sp-numArgs+i].Data\
        \}\
        result := builtinFn(args...)\
        \
        // Clean up stack\
        vm.sp = vm.sp - numArgs - 1\
        \
        if result != nil \{\
            var obj *Object\
            switch v := result.(type) \{\
            case int64:\
                obj = vm.gc.Allocate(ObjInteger, v)\
            case float64:\
                obj = vm.gc.Allocate(ObjFloat, v)\
            case string:\
                obj = vm.gc.Allocate(ObjString, v)\
            case bool:\
                obj = vm.gc.Allocate(ObjBoolean, v)\
            default:\
                obj = vm.gc.Allocate(ObjString, fmt.Sprintf("%v", v))\
            \}\
            vm.push(obj)\
        \}\
        \
    default:\
        return fmt.Errorf("calling non-function: %v", callee.Type)\
    \}\
    \
    return nil\
\}\
\
func (vm *VM) push(obj *Object) \{\
    vm.stack[vm.sp] = obj\
    vm.sp++\
    vm.gc.AddRoot(obj)\
\}\
\
func (vm *VM) pop() *Object \{\
    obj := vm.stack[vm.sp-1]\
    vm.sp--\
    vm.gc.RemoveRoot(obj)\
    return obj\
\}\
\
func (vm *VM) pushFrame(f *Frame) \{\
    vm.frames = append(vm.frames, f)\
\}\
\
func (vm *VM) popFrame() \{\
    vm.frames = vm.frames[:len(vm.frames)-1]\
\}\
\
func (vm *VM) currentFrame() *Frame \{\
    return vm.frames[len(vm.frames)-1]\
\}\
\
func (vm *VM) LastPoppedStackElem() *Object \{\
    return vm.stack[vm.sp]\
\}\
