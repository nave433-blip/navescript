### **`internal/oop/class.go`**\
```go\
package oop\
\
import (\
    "fmt"\
    "reflect"\
    "sync"\
)\
\
type Class struct \{\
    Name       string\
    SuperClass *Class\
    Methods    map[string]*Method\
    Fields     map[string]interface\{\}\
    Static     map[string]interface\{\}\
    mu         sync.RWMutex\
\}\
\
type Method struct \{\
    Name       string\
    Parameters []string\
    Body       func(instance *Object, args ...interface\{\}) interface\{\}\
    IsStatic   bool\
\}\
\
type Object struct \{\
    Class  *Class\
    Fields map[string]interface\{\}\
    mu     sync.RWMutex\
\}\
\
var classRegistry = make(map[string]*Class)\
var registryMu sync.RWMutex\
\
func NewClass(name string, superClass *Class) *Class \{\
    class := &Class\{\
        Name:       name,\
        SuperClass: superClass,\
        Methods:    make(map[string]*Method),\
        Fields:     make(map[string]interface\{\}),\
        Static:     make(map[string]interface\{\}),\
    \}\
    \
    registryMu.Lock()\
    classRegistry[name] = class\
    registryMu.Unlock()\
    \
    return class\
\}\
\
func (c *Class) DefineMethod(name string, params []string, body func(*Object, ...interface\{\}) interface\{\}) \{\
    c.mu.Lock()\
    defer c.mu.Unlock()\
    \
    c.Methods[name] = &Method\{\
        Name:       name,\
        Parameters: params,\
        Body:       body,\
        IsStatic:   false,\
    \}\
\}\
\
func (c *Class) DefineStaticMethod(name string, params []string, body func(...interface\{\}) interface\{\}) \{\
    c.mu.Lock()\
    defer c.mu.Unlock()\
    \
    c.Methods[name] = &Method\{\
        Name:       name,\
        Parameters: params,\
        Body:       func(instance *Object, args ...interface\{\}) interface\{\} \{ return body(args...) \},\
        IsStatic:   true,\
    \}\
\}\
\
func (c *Class) DefineField(name string, defaultValue interface\{\}) \{\
    c.mu.Lock()\
    defer c.mu.Unlock()\
    c.Fields[name] = defaultValue\
\}\
\
func (c *Class) DefineStaticField(name string, value interface\{\}) \{\
    c.mu.Lock()\
    defer c.mu.Unlock()\
    c.Static[name] = value\
\}\
\
func (c *Class) New(args ...interface\{\}) *Object \{\
    obj := &Object\{\
        Class:  c,\
        Fields: make(map[string]interface\{\}),\
    \}\
    \
    // Initialize fields from class defaults\
    c.mu.RLock()\
    for name, value := range c.Fields \{\
        obj.Fields[name] = value\
    \}\
    c.mu.RUnlock()\
    \
    // Call constructor if exists\
    if constructor, ok := c.Methods["__init__"]; ok \{\
        constructor.Body(obj, args...)\
    \}\
    \
    return obj\
\}\
\
func (c *Class) GetMethod(name string) (*Method, bool) \{\
    c.mu.RLock()\
    method, ok := c.Methods[name]\
    c.mu.RUnlock()\
    \
    if !ok && c.SuperClass != nil \{\
        return c.SuperClass.GetMethod(name)\
    \}\
    \
    return method, ok\
\}\
\
func (obj *Object) GetField(name string) (interface\{\}, bool) \{\
    obj.mu.RLock()\
    defer obj.mu.RUnlock()\
    \
    value, ok := obj.Fields[name]\
    if ok \{\
        return value, true\
    \}\
    \
    // Check class fields\
    obj.Class.mu.RLock()\
    value, ok = obj.Class.Fields[name]\
    obj.Class.mu.RUnlock()\
    \
    return value, ok\
\}\
\
func (obj *Object) SetField(name string, value interface\{\}) \{\
    obj.mu.Lock()\
    defer obj.mu.Unlock()\
    obj.Fields[name] = value\
\}\
\
func (obj *Object) CallMethod(name string, args ...interface\{\}) interface\{\} \{\
    method, ok := obj.Class.GetMethod(name)\
    if !ok \{\
        panic(fmt.Sprintf("method not found: %s", name))\
    \}\
    \
    if method.IsStatic \{\
        return method.Body(nil, args...)\
    \}\
    \
    return method.Body(obj, args...)\
\}\
\
func GetClass(name string) (*Class, bool) \{\
    registryMu.RLock()\
    defer registryMu.RUnlock()\
    class, ok := classRegistry[name]\
    return class, ok\
\}\
\
func Inherit(childName string, parentClass *Class) *Class \{\
    child := NewClass(childName, parentClass)\
    \
    // Copy methods from parent\
    parentClass.mu.RLock()\
    for name, method := range parentClass.Methods \{\
        if !method.IsStatic \{\
            child.Methods[name] = method\
        \}\
    \}\
    parentClass.mu.RUnlock()\
    \
    return child\
\}\
\
func (obj *Object) String() string \{\
    if method, ok := obj.Class.GetMethod("__str__"); ok \{\
        result := method.Body(obj)\
        if str, ok := result.(string); ok \{\
            return str\
        \}\
    \}\
    return fmt.Sprintf("<%s object at %p>", obj.Class.Name, obj)\
\}\
\
func (obj *Object) Equals(other *Object) bool \{\
    if obj.Class != other.Class \{\
        return false\
    \}\
    \
    if method, ok := obj.Class.GetMethod("__eq__"); ok \{\
        result := method.Body(obj, other)\
        if eq, ok := result.(bool); ok \{\
            return eq\
        \}\
    \}\
    \
    return obj == other\
\}\
