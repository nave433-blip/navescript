**`internal/vm/builtins.go`**\
```go\
package vm\
\
import (\
    "fmt"\
    "reflect"\
)\
\
var builtins = map[string]func(...interface\{\}) interface\{\}\{\
    "print": func(args ...interface\{\}) interface\{\} \{\
        for _, arg := range args \{\
            fmt.Print(arg)\
        \}\
        fmt.Println()\
        return nil\
    \},\
    \
    "len": func(args ...interface\{\}) interface\{\} \{\
        if len(args) != 1 \{\
            panic(fmt.Sprintf("len expects 1 argument, got %d", len(args)))\
        \}\
        \
        val := reflect.ValueOf(args[0])\
        switch val.Kind() \{\
        case reflect.String, reflect.Array, reflect.Slice, reflect.Map:\
            return int64(val.Len())\
        default:\
            panic(fmt.Sprintf("len not supported on type %T", args[0]))\
        \}\
    \},\
    \
    "type_of": func(args ...interface\{\}) interface\{\} \{\
        if len(args) != 1 \{\
            panic(fmt.Sprintf("type_of expects 1 argument, got %d", len(args)))\
        \}\
        return fmt.Sprintf("%T", args[0])\
    \},\
    \
    "input": func(args ...interface\{\}) interface\{\} \{\
        if len(args) > 0 \{\
            fmt.Print(args[0])\
        \}\
        var input string\
        fmt.Scanln(&input)\
        return input\
    \},\
    \
    "int": func(args ...interface\{\}) interface\{\} \{\
        if len(args) != 1 \{\
            panic(fmt.Sprintf("int expects 1 argument, got %d", len(args)))\
        \}\
        \
        switch v := args[0].(type) \{\
        case int64:\
            return v\
        case float64:\
            return int64(v)\
        case string:\
            var result int64\
            fmt.Sscanf(v, "%d", &result)\
            return result\
        default:\
            panic(fmt.Sprintf("cannot convert %T to int", args[0]))\
        \}\
    \},\
    \
    "float": func(args ...interface\{\}) interface\{\} \{\
        if len(args) != 1 \{\
            panic(fmt.Sprintf("float expects 1 argument, got %d", len(args)))\
        \}\
        \
        switch v := args[0].(type) \{\
        case int64:\
            return float64(v)\
        case float64:\
            return v\
        case string:\
            var result float64\
            fmt.Sscanf(v, "%f", &result)\
            return result\
        default:\
            panic(fmt.Sprintf("cannot convert %T to float", args[0]))\
        \}\
    \},\
    \
    "string": func(args ...interface\{\}) interface\{\} \{\
        if len(args) != 1 \{\
            panic(fmt.Sprintf("string expects 1 argument, got %d", len(args)))\
        \}\
        return fmt.Sprintf("%v", args[0])\
    \},\
    \
    "array": func(args ...interface\{\}) interface\{\} \{\
        return args\
    \},\
    \
    "panic": func(args ...interface\{\}) interface\{\} \{\
        msg := "panic"\
        if len(args) > 0 \{\
            msg = fmt.Sprintf("%v", args[0])\
        \}\
        panic(msg)\
    \},\
\}\
