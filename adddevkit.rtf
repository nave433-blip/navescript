    for _, bp := range d.breakpoints \{\
        if bp.File == file && bp.Line == line \{\
            if bp.Condition != "" \{\
                // Evaluate condition\
                result, err := d.Evaluate(bp.Condition)\
                if err == nil && result == true \{\
                    bp.HitCount++\
