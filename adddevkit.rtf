    client := &http.Client\{Timeout: 30 * time.Second\}\
    resp, err := client.Do(req)\
    if err != nil \{\
        return nil, err\
    \}\
    defer resp.Body.Close()\
    \
    respBody, err := ioutil.ReadAll(resp.Body)\
    if err != nil \{\
        return nil, err\
    \}\
    \
    return map[string]interface\{\}\{\
        "status": resp.StatusCode,\
        "body":   string(respBody),\
