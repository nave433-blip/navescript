### **`internal/concurrency/scheduler.go`** (M:N Scheduler)\
```go\
package concurrency\
\
import (\
    "runtime"\
    "sync"\
    "time"\
)\
\
type Task struct \{\
    ID        uint64\
    Func      func()\
    Priority  int\
    CreatedAt time.Time\
\}\
\
type Worker struct \{\
    ID    int\
    Tasks chan Task\
    Stop  chan bool\
\}\
\
type Scheduler struct \{\
    workers     []*Worker\
    taskQueue   chan Task\
    highPriority chan Task\
    wg          sync.WaitGroup\
    stop        chan bool\
    stats       SchedulerStats\
\}\
\
type SchedulerStats struct \{\
    TasksSubmitted   uint64\
    TasksCompleted   uint64\
    TasksFailed      uint64\
    AvgWaitTime      time.Duration\
    ActiveWorkers    int\
\}\
\
var globalScheduler *Scheduler\
\
func InitScheduler(numWorkers int) *Scheduler \{\
    if numWorkers == 0 \{\
        numWorkers = runtime.NumCPU() * 2\
    \}\
    \
    s := &Scheduler\{\
        workers:      make([]*Worker, numWorkers),\
        taskQueue:    make(chan Task, 10000),\
        highPriority: make(chan Task, 1000),\
        stop:         make(chan bool),\
    \}\
    \
    for i := 0; i < numWorkers; i++ \{\
        worker := &Worker\{\
            ID:    i,\
            Tasks: make(chan Task, 100),\
            Stop:  make(chan bool),\
        \}\
        s.workers[i] = worker\
        s.wg.Add(1)\
        go s.runWorker(worker)\
    \}\
    \
    // Task distributor\
    go s.distribute()\
    \
    globalScheduler = s\
    return s\
\}\
\
func (s *Scheduler) distribute() \{\
    for \{\
        select \{\
        case task := <-s.highPriority:\
            s.assignTask(task)\
        case task := <-s.taskQueue:\
            s.assignTask(task)\
        case <-s.stop:\
            return\
        \}\
    \}\
\}\
\
func (s *Scheduler) assignTask(task Task) \{\
    // Find least busy worker\
    var bestWorker *Worker\
    minLoad := int(^uint(0) >> 1)\
    \
    for _, worker := range s.workers \{\
        load := len(worker.Tasks)\
        if load < minLoad \{\
            minLoad = load\
            bestWorker = worker\
            if load == 0 \{\
                break\
            \}\
        \}\
    \}\
    \
    if bestWorker != nil \{\
        bestWorker.Tasks <- task\
    \}\
\}\
\
func (s *Scheduler) runWorker(w *Worker) \{\
    defer s.wg.Done()\
    \
    for \{\
        select \{\
        case task := <-w.Tasks:\
            start := time.Now()\
            s.stats.TasksSubmitted++\
            \
            func() \{\
                defer func() \{\
                    if r := recover(); r != nil \{\
                        s.stats.TasksFailed++\
                    \}\
                \}()\
                \
                task.Func()\
                s.stats.TasksCompleted++\
                \
                waitTime := time.Since(start)\
                s.stats.AvgWaitTime = (s.stats.AvgWaitTime + waitTime) / 2\
            \}()\
            \
        case <-w.Stop:\
            return\
        case <-s.stop:\
            return\
        \}\
    \}\
\}\
\
func (s *Scheduler) Submit(fn func(), priority int) uint64 \{\
    task := Task\{\
        ID:        atomic.AddUint64(&s.stats.TasksSubmitted, 1),\
        Func:      fn,\
        Priority:  priority,\
        CreatedAt: time.Now(),\
    \}\
    \
    if priority > 0 \{\
        s.highPriority <- task\
    \} else \{\
        s.taskQueue <- task\
    \}\
    \
    return task.ID\
\}\
\
func (s *Scheduler) SubmitWait(fn func()) \{\
    done := make(chan bool)\
    s.Submit(func() \{\
        fn()\
        done <- true\
    \}, 0)\
    <-done\
\}\
\
func (s *Scheduler) Stop() \{\
    close(s.stop)\
    for _, w := range s.workers \{\
        close(w.Stop)\
    \}\
    s.wg.Wait()\
\}\
\
func (s *Scheduler) Stats() SchedulerStats \{\
    activeWorkers := 0\
    for _, w := range s.workers \{\
        if len(w.Tasks) > 0 \{\
            activeWorkers++\
        \}\
    \}\
    s.stats.ActiveWorkers = activeWorkers\
    return s.stats\
\}\
\
// Convenience functions\
func GoFunc(fn func()) uint64 \{\
    if globalScheduler == nil \{\
        InitScheduler(0)\
    \}\
    return globalScheduler.Submit(fn, 0)\
\}\
\
func GoFuncPriority(fn func(), priority int) uint64 \{\
    if globalScheduler == nil \{\
        InitScheduler(0)\
    \}\
    return globalScheduler.Submit(fn, priority)\
\}\
\
func WaitFunc(id uint64) \{\
    // Simplified - would need to track task completion\
    for globalScheduler.stats.TasksCompleted < id \{\
        runtime.Gosched()\
    \}\
\}\
