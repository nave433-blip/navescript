import (\
    "bytes"\
    "fmt"\
    "os"\
    "os/exec"\
    "path/filepath"\
)\
\
type NASMEngine struct\{\}\
\
func (e *NASMEngine) Name() string \{ return "asm" \}\
\
func (e *NASMEngine) Execute(code string, args []string) (string, error) \{\
    tmpDir, err := os.MkdirTemp("", "nvs_asm_*")\
    if err != nil \{\
        return "", err\
    \}\
    defer os.RemoveAll(tmpDir)\
    \
    // Write assembly\
    asmFile := filepath.Join(tmpDir, "code.asm")\
    if err := os.WriteFile(asmFile, []byte(code), 0644); err != nil \{\
        return "", err\
    \}\
    \
    // Assemble with NASM\
    objFile := filepath.Join(tmpDir, "code.o")\
    cmd := exec.Command("nasm", "-f", "elf64", asmFile, "-o", objFile)\
    if err := cmd.Run(); err != nil \{\
        return "", fmt.Errorf("nasm error: %v", err)\
    \}\
    \
    // Link with ld\
    binFile := filepath.Join(tmpDir, "code")\
    cmd = exec.Command("ld", objFile, "-o", binFile)\
    if err := cmd.Run(); err != nil \{\
        return "", fmt.Errorf("ld error: %v", err)\
    \}\
    \
    // Execute\
    cmd = exec.Command(binFile, args...)\
    var stdout, stderr bytes.Buffer\
    cmd.Stdout = &stdout\
    cmd.Stderr = &stderr\
    \
    if err := cmd.Run(); err != nil \{\
        return "", fmt.Errorf("execution error: %s\\n%s", err, stderr.String())\
    \}\
    \
    return stdout.String(), nil\
\}\
