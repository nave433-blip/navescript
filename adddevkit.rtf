import (\
    "encoding/json"\
    "fmt"\
)\
\
// Built-in classes\
var (\
    ObjectClass   *Class\
    ClassClass    *Class\
    StringClass   *Class\
    IntegerClass  *Class\
    FloatClass    *Class\
    BooleanClass  *Class\
    ArrayClass    *Class\
    HashClass     *Class\
)\
\
func init() \{\
    // Initialize base Object class\
    ObjectClass = NewClass("Object", nil)\
    ObjectClass.DefineMethod("__init__", []string\{\}, func(obj *Object, args ...interface\{\}) interface\{\} \{ return nil \})\
    ObjectClass.DefineMethod("__str__", []string\{\}, func(obj *Object, args ...interface\{\}) interface\{\} \{ \
        return fmt.Sprintf("<%s object>", obj.Class.Name)\
    \})\
    ObjectClass.DefineMethod("__eq__", []string\{"other"\}, func(obj *Object, args ...interface\{\}) interface\{\} \{\
        return obj == args[0]\
    \})\
    \
    // Class class (metaclass)\
    ClassClass = NewClass("Class", ObjectClass)\
    \
    // String class\
    StringClass = NewClass("String", ObjectClass)\
    StringClass.DefineMethod("__init__", []string\{"value"\}, func(obj *Object, args ...interface\{\}) interface\{\} \{\
        obj.SetField("value", args[0])\
        return nil\
    \})\
    StringClass.DefineMethod("__str__", []string\{\}, func(obj *Object, args ...interface\{\}) interface\{\} \{\
        val, _ := obj.GetField("value")\
        return val\
    \})\
    StringClass.DefineMethod("length", []string\{\}, func(obj *Object, args ...interface\{\}) interface\{\} \{\
        val, _ := obj.GetField("value")\
        return len(val.(string))\
    \})\
    StringClass.DefineMethod("upper", []string\{\}, func(obj *Object, args ...interface\{\}) interface\{\} \{\
        val, _ := obj.GetField("value")\
        return StringClass.New(val.(string))\
    \})\
    \
    // Integer class\
    IntegerClass = NewClass("Integer", ObjectClass)\
    IntegerClass.DefineMethod("__init__", []string\{"value"\}, func(obj *Object, args ...interface\{\}) interface\{\} \{\
        obj.SetField("value", args[0])\
        return nil\
    \})\
    IntegerClass.DefineMethod("__str__", []string\{\}, func(obj *Object, args ...interface\{\}) interface\{\} \{\
        val, _ := obj.GetField("value")\
        return fmt.Sprintf("%v", val)\
    \})\
    IntegerClass.DefineMethod("__add__", []string\{"other"\}, func(obj *Object, args ...interface\{\}) interface\{\} \{\
        left, _ := obj.GetField("value")\
        right, _ := args[0].(*Object).GetField("value")\
        return IntegerClass.New(left.(int64) + right.(int64))\
    \})\
    \
    // Boolean class\
    BooleanClass = NewClass("Boolean", ObjectClass)\
    \
    // Array class\
    ArrayClass = NewClass("Array", ObjectClass)\
    ArrayClass.DefineMethod("__init__", []string\{\}, func(obj *Object, args ...interface\{\}) interface\{\} \{\
        obj.SetField("items", []interface\{\}\{\})\
        return nil\
    \})\
    ArrayClass.DefineMethod("push", []string\{"item"\}, func(obj *Object, args ...interface\{\}) interface\{\} \{\
        items, _ := obj.GetField("items")\
        items = append(items.([]interface\{\}), args[0])\
        obj.SetField("items", items)\
        return nil\
    \})\
    ArrayClass.DefineMethod("pop", []string\{\}, func(obj *Object, args ...interface\{\}) interface\{\} \{\
        items, _ := obj.GetField("items")\
        if len(items.([]interface\{\})) == 0 \{\
            return nil\
        \}\
        last := items.([]interface\{\})[len(items.([]interface\{\}))-1]\
        items = items.([]interface\{\})[:len(items.([]interface\{\}))-1]\
        obj.SetField("items", items)\
        return last\
    \})\
    ArrayClass.DefineMethod("length", []string\{\}, func(obj *Object, args ...interface\{\}) interface\{\} \{\
        items, _ := obj.GetField("items")\
        return len(items.([]interface\{\}))\
    \})\
    \
    // Hash class\
    HashClass = NewClass("Hash", ObjectClass)\
    HashClass.DefineMethod("__init__", []string\{\}, func(obj *Object, args ...interface\{\}) interface\{\} \{\
        obj.SetField("items", make(map[string]interface\{\}))\
        return nil\
    \})\
    HashClass.DefineMethod("set", []string\{"key", "value"\}, func(obj *Object, args ...interface\{\}) interface\{\} \{\
        items, _ := obj.GetField("items")\
        items.(map[string]interface\{\})[args[0].(string)] = args[1]\
        obj.SetField("items", items)\
        return nil\
    \})\
    HashClass.DefineMethod("get", []string\{"key"\}, func(obj *Object, args ...interface\{\}) interface\{\} \{\
        items, _ := obj.GetField("items")\
        return items.(map[string]interface\{\})[args[0].(string)]\
    \})\
\}\
\
func NewString(value string) *Object \{\
    obj := StringClass.New()\
    obj.SetField("value", value)\
    return obj\
\}\
\
func NewInteger(value int64) *Object \{\
    obj := IntegerClass.New()\
    obj.SetField("value", value)\
    return obj\
\}\
\
func NewBoolean(value bool) *Object \{\
    obj := BooleanClass.New()\
    obj.SetField("value", value)\
    return obj\
\}\
\
func NewArray(items ...interface\{\}) *Object \{\
    obj := ArrayClass.New()\
    obj.SetField("items", items)\
    return obj\
\}\
\
func NewHash(items map[string]interface\{\}) *Object \{\
    obj := HashClass.New()\
    obj.SetField("items", items)\
    return obj\
\}\
\
func (obj *Object) ToJSON() (string, error) \{\
    data, err := json.Marshal(obj.Fields)\
    if err != nil \{\
        return "", err\
    \}\
    return string(data), nil\
\}\
