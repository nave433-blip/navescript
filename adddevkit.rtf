**`internal/repl/repl.go`**\
```go\
package repl\
\
import (\
    "bufio"\
    "fmt"\
    "io"\
    "os"\
    "strings"\
    \
    "github.com/navescript/nvs/internal/lexer"\
    "github.com/navescript/nvs/internal/parser"\
    "github.com/navescript/nvs/internal/compiler"\
    "github.com/navescript/nvs/internal/vm"\
)\
\
const PROMPT = ">> "\
const HISTORY_FILE = ".nvs_history"\
\
type REPL struct \{\
    history []string\
    index   int\
\}\
\
func Start() \{\
    repl := &REPL\{\
        history: make([]string, 0),\
        index:   0,\
    \}\
    \
    repl.loadHistory()\
    \
    fmt.Println("NaveScript REPL v0.1.0")\
    fmt.Println("Type :help for help, :exit to quit")\
    \
    scanner := bufio.NewScanner(os.Stdin)\
    \
    for \{\
        fmt.Print(PROMPT)\
        \
        if !scanner.Scan() \{\
            break\
        \}\
        \
        line := scanner.Text()\
        \
        // Handle commands\
        if strings.HasPrefix(line, ":") \{\
            repl.handleCommand(line)\
            continue\
        \}\
        \
        // Add to history\
        if line != "" \{\
            repl.addToHistory(line)\
        \}\
        \
        // Evaluate\
        result := repl.evaluate(line)\
        if result != "" \{\
            fmt.Println(result)\
        \}\
    \}\
\}\
\
func (r *REPL) evaluate(input string) string \{\
    l := lexer.New(input)\
    p := parser.New(l)\
    program := p.ParseProgram()\
    \
    if len(p.Errors()) > 0 \{\
        return p.Errors()[0]\
    \}\
    \
    comp := compiler.New()\
    if err := comp.Compile(program); err != nil \{\
        return err.Error()\
    \}\
    \
    machine := vm.New(comp.Bytecode())\
    if err := machine.Run(); err != nil \{\
        return err.Error()\
    \}\
    \
    last := machine.LastPoppedStackElem()\
    if last != nil \{\
        return fmt.Sprintf("%v", last.Data)\
    \}\
    \
    return ""\
\}\
\
func (r *REPL) handleCommand(cmd string) \{\
    parts := strings.Fields(cmd)\
    if len(parts) == 0 \{\
        return\
    \}\
    \
    switch parts[0] \{\
    case ":exit", ":quit":\
        r.saveHistory()\
        os.Exit(0)\
        \
    case ":help":\
        fmt.Println("Commands:")\
        fmt.Println("  :exit, :quit  - Exit the REPL")\
        fmt.Println("  :help         - Show this help")\
        fmt.Println("  :history      - Show command history")\
        fmt.Println("  :clear        - Clear screen")\
        fmt.Println("  :load <file>  - Load and run a file")\
        \
    case ":history":\
        for i, h := range r.history \{\
            fmt.Printf("%d: %s\\n", i+1, h)\
        \}\
        \
    case ":clear":\
        fmt.Print("\\033[H\\033[2J")\
        \
    case ":load":\
        if len(parts) < 2 \{\
            fmt.Println("Usage: :load <filename>")\
            return\
        \}\
        \
        data, err := os.ReadFile(parts[1])\
        if err != nil \{\
            fmt.Printf("Error: %v\\n", err)\
            return\
        \}\
        \
        result := r.evaluate(string(data))\
        if result != "" \{\
            fmt.Println(result)\
        \}\
        \
    default:\
        fmt.Printf("Unknown command: %s\\n", parts[0])\
    \}\
\}\
\
func (r *REPL) addToHistory(line string) \{\
    r.history = append(r.history, line)\
    if len(r.history) > 1000 \{\
        r.history = r.history[1:]\
    \}\
    r.index = len(r.history)\
\}\
\
func (r *REPL) loadHistory() \{\
    data, err := os.ReadFile(HISTORY_FILE)\
    if err != nil \{\
        return\
    \}\
    \
    lines := strings.Split(string(data), "\\n")\
    for _, line := range lines \{\
        if line != "" \{\
            r.history = append(r.history, line)\
        \}\
    \}\
    r.index = len(r.history)\
\}\
\
func (r *REPL) saveHistory() \{\
    file, err := os.Create(HISTORY_FILE)\
    if err != nil \{\
        return\
    \}\
    defer file.Close()\
    \
    for _, line := range r.history \{\
        fmt.Fprintln(file, line)\
    \}\
\}\
