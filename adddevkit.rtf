**`cmd/nvs-debug/main.go`**\
```go\
package main\
\
import (\
    "encoding/json"\
    "fmt"\
    "io"\
    "os"\
    \
    "github.com/navescript/nvs/internal/debugger"\
    "github.com/navescript/nvs/internal/lexer"\
    "github.com/navescript/nvs/internal/parser"\
    "github.com/navescript/nvs/internal/compiler"\
    "github.com/navescript/nvs/internal/vm"\
)\
\
func main() \{\
    if len(os.Args) < 2 \{\
        fmt.Println("Usage: nvs-debug <file.nvs>")\
        os.Exit(1)\
    \}\
    \
    filename := os.Args[1]\
    source, err := os.ReadFile(filename)\
    if err != nil \{\
        fmt.Printf("Error reading file: %v\\n", err)\
        os.Exit(1)\
    \}\
    \
    // Parse and compile\
    l := lexer.New(string(source))\
    p := parser.New(l)\
    program := p.ParseProgram()\
    \
    if len(p.Errors()) > 0 \{\
        for _, err := range p.Errors() \{\
            fmt.Printf("Parse error: %s\\n", err)\
        \}\
        os.Exit(1)\
    \}\
    \
    comp := compiler.New()\
    if err := comp.Compile(program); err != nil \{\
        fmt.Printf("Compile error: %v\\n", err)\
        os.Exit(1)\
    \}\
    \
    // Create VM with debugger\
    machine := vm.New(comp.Bytecode())\
    dbg := debugger.NewDebugger(machine)\
    \
    // Setup DAP protocol over stdio\
    dap := NewDAPServer(dbg)\
    dap.Run(os.Stdin, os.Stdout)\
\}\
\
type DAPServer struct \{\
    debugger *debugger.Debugger\
    seq      int\
\}\
\
func NewDAPServer(dbg *debugger.Debugger) *DAPServer \{\
    return &DAPServer\{\
        debugger: dbg,\
        seq:      1,\
    \}\
\}\
\
func (s *DAPServer) Run(input io.Reader, output io.Writer) \{\
    decoder := json.NewDecoder(input)\
    encoder := json.NewEncoder(output)\
    \
    for \{\
        var msg map[string]interface\{\}\
        if err := decoder.Decode(&msg); err != nil \{\
            break\
        \}\
        \
        s.handleMessage(msg, encoder)\
    \}\
\}\
\
func (s *DAPServer) handleMessage(msg map[string]interface\{\}, encoder *json.Encoder) \{\
    command, _ := msg["command"].(string)\
    args, _ := msg["arguments"].(map[string]interface\{\})\
    \
    var response map[string]interface\{\}\
    \
    switch command \{\
    case "initialize":\
        response = s.handleInitialize(args)\
    case "launch":\
        response = s.handleLaunch(args)\
    case "setBreakpoints":\
        response = s.handleSetBreakpoints(args)\
    case "continue":\
        response = s.handleContinue()\
    case "next":\
        response = s.handleNext()\
    case "stepIn":\
        response = s.handleStepIn()\
    case "stepOut":\
        response = s.handleStepOut()\
    case "pause":\
        response = s.handlePause()\
    case "stackTrace":\
        response = s.handleStackTrace(args)\
    case "scopes":\
        response = s.handleScopes(args)\
    case "variables":\
        response = s.handleVariables(args)\
    case "evaluate":\
        response = s.handleEvaluate(args)\
    case "disconnect":\
        response = s.handleDisconnect()\
    default:\
        response = map[string]interface\{\}\{\
            "type": "response",\
            "command": command,\
            "request_seq": msg["seq"],\
            "success": false,\
            "message": fmt.Sprintf("Unknown command: %s", command),\
        \}\
    \}\
    \
    response["seq"] = s.seq\
    s.seq++\
    response["request_seq"] = msg["seq"]\
    response["type"] = "response"\
    \
    encoder.Encode(response)\
\}\
\
func (s *DAPServer) handleInitialize(args map[string]interface\{\}) map[string]interface\{\} \{\
    return map[string]interface\{\}\{\
        "success": true,\
        "body": map[string]interface\{\}\{\
            "supportsConfigurationDoneRequest": true,\
            "supportsFunctionBreakpoints": false,\
            "supportsConditionalBreakpoints": true,\
            "supportsHitConditionalBreakpoints": true,\
            "supportsEvaluateForHovers": true,\
            "supportsSetVariable": false,\
            "supportsCompletionsRequest": false,\
            "supportsStepBack": false,\
            "supportsRestartFrame": false,\
            "supportsGotoTargetsRequest": false,\
            "supportsStepInTargetsRequest": false,\
            "supportsLogPoints": true,\
            "supportsLoadedSourcesRequest": false,\
            "supportsDataBreakpoints": false,\
            "supportsBreakpointLocationsRequest": false,\
            "supportsClipboardContext": false,\
        \},\
    \}\
\}\
\
func (s *DAPServer) handleLaunch(args map[string]interface\{\}) map[string]interface\{\} \{\
    return map[string]interface\{\}\{\
        "success": true,\
    \}\
\}\
\
func (s *DAPServer) handleSetBreakpoints(args map[string]interface\{\}) map[string]interface\{\} \{\
    source, _ := args["source"].(map[string]interface\{\})\
    sourcePath, _ := source["path"].(string)\
    breakpoints, _ := args["breakpoints"].([]interface\{\})\
    \
    breakpointInfos := []map[string]interface\{\}\{\}\
    \
    for _, bp := range breakpoints \{\
        bpMap, _ := bp.(map[string]interface\{\})\
        line, _ := bpMap["line"].(float64)\
        condition, _ := bpMap["condition"].(string)\
        \
        id := s.debugger.SetBreakpoint(sourcePath, int(line), condition)\
        \
        breakpointInfos = append(breakpointInfos, map[string]interface\{\}\{\
            "id": id,\
            "verified": true,\
            "line": line,\
        \})\
    \}\
    \
    return map[string]interface\{\}\{\
        "success": true,\
        "body": map[string]interface\{\}\{\
            "breakpoints": breakpointInfos,\
        \},\
    \}\
\}\
\
func (s *DAPServer) handleContinue() map[string]interface\{\} \{\
    s.debugger.Continue()\
    \
    return map[string]interface\{\}\{\
        "success": true,\
        "body": map[string]interface\{\}\{\
            "allThreadsContinued": true,\
        \},\
    \}\
\}\
\
func (s *DAPServer) handleNext() map[string]interface\{\} \{\
    s.debugger.StepOver()\
    return map[string]interface\{\}\{"success": true\}\
\}\
\
func (s *DAPServer) handleStepIn() map[string]interface\{\} \{\
    s.debugger.StepInto()\
    return map[string]interface\{\}\{"success": true\}\
\}\
\
func (s *DAPServer) handleStepOut() map[string]interface\{\} \{\
    s.debugger.StepOut()\
    return map[string]interface\{\}\{"success": true\}\
\}\
\
func (s *DAPServer) handlePause() map[string]interface\{\} \{\
    s.debugger.Pause()\
    return map[string]interface\{\}\{"success": true\}\
\}\
\
func (s *DAPServer) handleStackTrace(args map[string]interface\{\}) map[string]interface\{\} \{\
    frames := s.debugger.GetStackTrace()\
    \
    dapFrames := []map[string]interface\{\}\{\}\
    for i, frame := range frames \{\
        dapFrames = append(dapFrames, map[string]interface\{\}\{\
            "id": frame.ID,\
            "name": frame.Name,\
            "line": frame.Line,\
            "column": frame.Column,\
            "source": map[string]interface\{\}\{\
                "path": frame.File,\
            \},\
        \})\
        if i > 20 \{\
            break\
        \}\
    \}\
    \
    return map[string]interface\{\}\{\
        "success": true,\
        "body": map[string]interface\{\}\{\
            "stackFrames": dapFrames,\
            "totalFrames": len(frames),\
        \},\
    \}\
\}\
\
func (s *DAPServer) handleScopes(args map[string]interface\{\}) map[string]interface\{\} \{\
    frameId, _ := args["frameId"].(float64)\
    \
    variables := s.debugger.GetVariables(int(frameId))\
    \
    return map[string]interface\{\}\{\
        "success": true,\
        "body": map[string]interface\{\}\{\
            "scopes": []map[string]interface\{\}\{\
                \{\
                    "name": "Local",\
                    "variablesReference": len(variables),\
                    "expensive": false,\
                \},\
            \},\
        \},\
    \}\
\}\
\
func (s *DAPServer) handleVariables(args map[string]interface\{\}) map[string]interface\{\} \{\
    varsRef, _ := args["variablesReference"].(float64)\
    \
    // In a real implementation, this would fetch variables by reference\
    return map[string]interface\{\}\{\
        "success": true,\
        "body": map[string]interface\{\}\{\
            "variables": []map[string]interface\{\}\{\},\
        \},\
    \}\
\}\
\
func (s *DAPServer) handleEvaluate(args map[string]interface\{\}) map[string]interface\{\} \{\
    expression, _ := args["expression"].(string)\
    \
    result, err := s.debugger.Evaluate(expression)\
    if err != nil \{\
        return map[string]interface\{\}\{\
            "success": false,\
            "message": err.Error(),\
        \}\
    \}\
    \
    return map[string]interface\{\}\{\
        "success": true,\
        "body": map[string]interface\{\}\{\
            "result": fmt.Sprintf("%v", result),\
            "type": fmt.Sprintf("%T", result),\
            "variablesReference": 0,\
        \},\
    \}\
\}\
\
func (s *DAPServer) handleDisconnect() map[string]interface\{\} \{\
    os.Exit(0)\
    return map[string]interface\{\}\{"success": true\}\
\}\
