func (rm *RustModule) CallFunc(name string, args ...interface\{\}) (interface\{\}, error) \{\
    fn, err := rm.lib.GetFunc(name, reflect.TypeOf((*interface\{\})(nil)).Elem())\
    if err != nil \{\
        return nil, err\
    \}\
    return CallCFunc(fn, args...)\
\}\
\
func (rm *RustModule) Close() error \{\
    if rm.lib != nil \{\
        rm.lib.Close()\
    \}\
    return os.RemoveAll(rm.path)\
