**`internal/vm/gc.go`**\
```go\
package vm\
\
import (\
    "fmt"\
    "runtime"\
    "sync"\
    "time"\
)\
\
type GarbageCollector struct \{\
    objects    []*Object\
    roots      []*Object\
    mu         sync.RWMutex\
    threshold  int\
    lastCollect time.Time\
    enabled    bool\
\}\
\
type Object struct \{\
    Type      ObjectType\
    Data      interface\{\}\
    Marked    bool\
    References []*Object\
\}\
\
type ObjectType int\
\
const (\
    ObjInteger ObjectType = iota\
    ObjFloat\
    ObjString\
    ObjBoolean\
    ObjArray\
    ObjHash\
    ObjFunction\
    ObjClosure\
    ObjBuiltin\
)\
\
func NewGarbageCollector() *GarbageCollector \{\
    return &GarbageCollector\{\
        objects:   make([]*Object, 0),\
        roots:     make([]*Object, 0),\
        threshold: 1000,\
        enabled:   true,\
        lastCollect: time.Now(),\
    \}\
\}\
\
func (gc *GarbageCollector) Allocate(objType ObjectType, data interface\{\}) *Object \{\
    obj := &Object\{\
        Type:      objType,\
        Data:      data,\
        Marked:    false,\
        References: make([]*Object, 0),\
    \}\
    \
    gc.mu.Lock()\
    gc.objects = append(gc.objects, obj)\
    gc.mu.Unlock()\
    \
    if gc.enabled && len(gc.objects) > gc.threshold \{\
        gc.Collect()\
    \}\
    \
    return obj\
\}\
\
func (gc *GarbageCollector) AddRoot(obj *Object) \{\
    gc.mu.Lock()\
    defer gc.mu.Unlock()\
    gc.roots = append(gc.roots, obj)\
\}\
\
func (gc *GarbageCollector) RemoveRoot(obj *Object) \{\
    gc.mu.Lock()\
    defer gc.mu.Unlock()\
    for i, root := range gc.roots \{\
        if root == obj \{\
            gc.roots = append(gc.roots[:i], gc.roots[i+1:]...)\
            break\
        \}\
    \}\
\}\
\
func (gc *GarbageCollector) Mark(obj *Object) \{\
    if obj == nil || obj.Marked \{\
        return\
    \}\
    \
    obj.Marked = true\
    \
    for _, ref := range obj.References \{\
        gc.Mark(ref)\
    \}\
\}\
\
func (gc *GarbageCollector) Sweep() \{\
    gc.mu.Lock()\
    defer gc.mu.Unlock()\
    \
    remaining := make([]*Object, 0)\
    for _, obj := range gc.objects \{\
        if obj.Marked \{\
            obj.Marked = false\
            remaining = append(remaining, obj)\
        \} else \{\
            // Object is garbage, free it\
            gc.freeObject(obj)\
        \}\
    \}\
    gc.objects = remaining\
\}\
\
func (gc *GarbageCollector) freeObject(obj *Object) \{\
    // Clear references\
    obj.References = nil\
    obj.Data = nil\
    \
    // Allow GC to collect the Go objects\
    runtime.Gosched()\
\}\
\
func (gc *GarbageCollector) Collect() \{\
    if !gc.enabled \{\
        return\
    \}\
    \
    gc.mu.Lock()\
    defer gc.mu.Unlock()\
    \
    // Mark phase - start from roots\
    for _, root := range gc.roots \{\
        gc.Mark(root)\
    \}\
    \
    // Sweep phase\
    remaining := make([]*Object, 0)\
    for _, obj := range gc.objects \{\
        if obj.Marked \{\
            obj.Marked = false\
            remaining = append(remaining, obj)\
        \} else \{\
            gc.freeObject(obj)\
        \}\
    \}\
    gc.objects = remaining\
    \
    gc.lastCollect = time.Now()\
    \
    // Adaptive threshold\
    if len(gc.objects) > gc.threshold*2 \{\
        gc.threshold = len(gc.objects) / 2\
    \} else if len(gc.objects) < gc.threshold/2 \{\
        gc.threshold = len(gc.objects)\
    \}\
\}\
\
func (gc *GarbageCollector) Enable() \{\
    gc.enabled = true\
\}\
\
func (gc *GarbageCollector) Disable() \{\
    gc.enabled = false\
\}\
\
func (gc *GarbageCollector) Stats() map[string]interface\{\} \{\
    gc.mu.RLock()\
    defer gc.mu.RUnlock()\
    \
    return map[string]interface\{\}\{\
        "objects":     len(gc.objects),\
        "threshold":   gc.threshold,\
        "last_collect": gc.lastCollect,\
        "enabled":     gc.enabled,\
    \}\
\}\
