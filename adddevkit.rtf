// Standard testing module\
let passed = 0\
let failed = 0\
let failures = []\
\
func assert(condition, message) \{\
    if condition \{\
        passed = passed + 1\
        print("\uc0\u10003  " + message)\
    \} else \{\
        failed = failed + 1\
        failures = failures + [message]\
        print("\uc0\u10007  " + message)\
    \}\
\}\
\
func run(tests) \{\
    print("\\nRunning " + len(tests) + " tests...\\n")\
    \
    let start = time.now()\
    \
    for test in tests \{\
        print("\\n--- Running " + test.name + " ---")\
        test()\
    \}\
    \
    let duration = time.now() - start\
    \
    print("\\n" + "=" * 50)\
    print("Test Results:")\
    print("  Passed: " + passed)\
    print("  Failed: " + failed)\
    print("  Total:  " + (passed + failed))\
    print("  Time:   " + duration + "ms")\
    \
    if failed > 0 \{\
        print("\\nFailures:")\
        for failure in failures \{\
            print("  - " + failure)\
        \}\
        print("\\n\uc0\u10060  " + failed + " test(s) failed")\
        exit(1)\
    \} else \{\
        print("\\n\uc0\u9989  All tests passed!")\
    \}\
\}\
