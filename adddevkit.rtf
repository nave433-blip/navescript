func parseWASM(data []byte) (*WASMModule, error) \{\
    if len(data) < 8 \{\
        return nil, fmt.Errorf("invalid WASM binary")\
    \}\
    \
    magic := binary.LittleEndian.Uint32(data[0:4])\
    version := binary.LittleEndian.Uint32(data[4:8])\
    \
    if magic != 0x6D736100 \{\
        return nil, fmt.Errorf("invalid magic number")\
    \}\
    \
    module := &WASMModule\{\
        Magic:   magic,\
        Version: version,\
    \}\
    \
    pos := 8\
    for pos < len(data) \{\
        id := data[pos]\
        pos++\
        \
        size, n := readULEB128(data[pos:])\
        pos += n\
        \
        sectionData := data[pos : pos+int(size)]\
        module.Sections = append(module.Sections, WASMSection\{\
            ID:   id,\
            Data: sectionData,\
        \})\
        \
        pos += int(size)\
    \}\
    \
    return module, nil\
\}\
\
func readULEB128(data []byte) (uint32, int) \{\
    var result uint32\
    var shift uint\
    var i int\
    \
    for i = 0; i < len(data); i++ \{\
        b := data[i]\
        result |= uint32(b&0x7F) << shift\
        shift += 7\
        if (b & 0x80) == 0 \{\
            break\
        \}\
    \}\
    \
    return result, i + 1\
\}\
