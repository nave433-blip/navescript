func (g *DocGenerator) getOrCreatePackage(filename string) *PackageDoc \{\
    dir := filepath.Dir(filename)\
    pkgName := filepath.Base(dir)\
    \
    if pkg, ok := g.Packages[pkgName]; ok \{\
        return pkg\
    \}\
    \
    pkg := &PackageDoc\{\
        Name:      pkgName,\
        Functions: []*FunctionDoc\{\},\
        Types:     []*TypeDoc\{\},\
        Constants: []*ConstantDoc\{\},\
    \}\
    g.Packages[pkgName] = pkg\
    return pkg\
\}\
\
func (g *DocGenerator) WriteHTML() error \{\
    tmpl := `<!DOCTYPE html>\
<html>\
<head>\
    <title>NaveScript Documentation</title>\
    <style>\
        body \{ font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif; line-height: 1.6; max-width: 1200px; margin: 0 auto; padding: 20px; \}\
        h1 \{ border-bottom: 1px solid #eaecef; padding-bottom: 10px; \}\
        h2 \{ margin-top: 30px; \}\
        .package \{ margin-bottom: 40px; \}\
        .function \{ background: #f6f8fa; padding: 15px; margin: 15px 0; border-radius: 5px; border-left: 4px solid #0366d6; \}\
        .function-name \{ font-family: monospace; font-size: 1.2em; font-weight: bold; color: #0366d6; \}\
        .function-signature \{ font-family: monospace; color: #6a737d; margin: 5px 0; \}\
        .function-description \{ margin: 10px 0; \}\
        .param \{ margin: 5px 0; \}\
        .param-name \{ font-family: monospace; font-weight: bold; \}\
        .returns \{ margin-top: 10px; color: #22863a; \}\
        .example \{ background: #f1f8ff; padding: 10px; border-radius: 3px; font-family: monospace; margin: 10px 0; \}\
        .sidebar \{ position: fixed; left: 0; top: 0; width: 250px; height: 100%; background: #f6f8fa; padding: 20px; overflow-y: auto; \}\
        .content \{ margin-left: 270px; \}\
        @media (max-width: 768px) \{ .sidebar \{ display: none; \} .content \{ margin-left: 0; \} \}\
        .nav-link \{ display: block; padding: 5px 0; color: #0366d6; text-decoration: none; \}\
        .nav-link:hover \{ text-decoration: underline; \}\
    </style>\
</head>\
<body>\
    <div class="sidebar">\
        <h3>Packages</h3>\
        \{\{range $name, $pkg := .Packages\}\}\
            <a href="#\{\{$name\}\}" class="nav-link">\{\{$name\}\}</a>\
        \{\{end\}\}\
    </div>\
    <div class="content">\
        <h1>NaveScript Standard Library</h1>\
        \
        \{\{range $name, $pkg := .Packages\}\}\
            <div class="package" id="\{\{$name\}\}">\
                <h2>Package \{\{$name\}\}</h2>\
                <p>\{\{$pkg.Description\}\}</p>\
                \
                \{\{if $pkg.Functions\}\}\
                    <h3>Functions</h3>\
                    \{\{range $pkg.Functions\}\}\
                        <div class="function">\
                            <div class="function-name">\{\{.Name\}\}</div>\
                            <div class="function-signature">\{\{.Signature\}\}</div>\
                            <div class="function-description">\{\{.Description\}\}</div>\
                            \{\{if .Parameters\}\}\
                                <div class="parameters">\
                                    <strong>Parameters:</strong>\
                                    \{\{range .Parameters\}\}\
                                        <div class="param"><span class="param-name">\{\{.\}\}</span></div>\
                                    \{\{end\}\}\
                                </div>\
                            \{\{end\}\}\
                            \{\{if .Returns\}\}\
                                <div class="returns"><strong>Returns:</strong> \{\{.Returns\}\}</div>\
                            \{\{end\}\}\
                            \{\{if .Examples\}\}\
                                <div class="examples">\
                                    <strong>Examples:</strong>\
                                    \{\{range .Examples\}\}\
                                        <div class="example">\{\{.\}\}</div>\
                                    \{\{end\}\}\
                                </div>\
                            \{\{end\}\}\
                        </div>\
                    \{\{end\}\}\
                \{\{end\}\}\
            </div>\
        \{\{end\}\}\
    </div>\
</body>\
</html>`\
    \
    t, err := template.New("docs").Parse(tmpl)\
    if err != nil \{\
        return err\
    \}\
    \
    outputFile := filepath.Join(g.OutputDir, "index.html")\
    f, err := os.Create(outputFile)\
    if err != nil \{\
        return err\
    \}\
    defer f.Close()\
    \
    return t.Execute(f, map[string]interface\{\}\{\
        "Packages": g.Packages,\
    \})\
\}\
\
func (g *DocGenerator) WriteMarkdown() error \{\
    var buf bytes.Buffer\
    \
    for name, pkg := range g.Packages \{\
        buf.WriteString(fmt.Sprintf("# Package %s\\n\\n", name))\
        buf.WriteString(pkg.Description + "\\n\\n")\
        \
        for _, fn := range pkg.Functions \{\
            buf.WriteString(fmt.Sprintf("## %s\\n\\n", fn.Name))\
            buf.WriteString(fmt.Sprintf("```nvs\\n%s\\n```\\n\\n", fn.Signature))\
            buf.WriteString(fn.Description + "\\n\\n")\
            \
            if len(fn.Parameters) > 0 \{\
                buf.WriteString("**Parameters:**\\n\\n")\
                for _, p := range fn.Parameters \{\
                    buf.WriteString(fmt.Sprintf("- `%s`\\n", p))\
                \}\
                buf.WriteString("\\n")\
            \}\
            \
            if fn.Returns != "" \{\
                buf.WriteString(fmt.Sprintf("**Returns:** %s\\n\\n", fn.Returns))\
            \}\
        \}\
    \}\
    \
    return os.WriteFile(filepath.Join(g.OutputDir, "API.md"), buf.Bytes(), 0644)\
\}\
