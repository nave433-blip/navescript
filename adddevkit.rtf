    \
    tx, err := conn.DB.Begin()\
    if err != nil \{\
        return nil, err\
    \}\
    \
    txID := fmt.Sprintf("%s_tx_%p", name, tx)\
    \
    return map[string]interface\{\}\{\
        "id": txID,\
    \}, nil\
