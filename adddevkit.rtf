### **`internal/profiling/coverage.go`**\
```go\
package profiling\
\
import (\
    "fmt"\
    "sync"\
)\
\
type CoverageProfiler struct \{\
    mu       sync.RWMutex\
    covered  map[string]map[int]bool\
    total    map[string]map[int]bool\
    enabled  bool\
\}\
\
type CoverageReport struct \{\
    Files      []FileCoverage\
    TotalLines int\
    CoveredLines int\
    Percentage float64\
\}\
\
type FileCoverage struct \{\
    File       string\
    TotalLines int\
    CoveredLines int\
    Lines      map[int]bool\
    Percentage float64\
\}\
\
func NewCoverageProfiler() *CoverageProfiler \{\
    return &CoverageProfiler\{\
        covered: make(map[string]map[int]bool),\
        total:   make(map[string]map[int]bool),\
        enabled: true,\
    \}\
\}\
\
func (p *CoverageProfiler) MarkLine(file string, line int) \{\
    if !p.enabled \{\
        return\
    \}\
    \
    p.mu.Lock()\
    defer p.mu.Unlock()\
    \
    if _, ok := p.covered[file]; !ok \{\
        p.covered[file] = make(map[int]bool)\
        p.total[file] = make(map[int]bool)\
    \}\
    \
    p.covered[file][line] = true\
    p.total[file][line] = true\
\}\
\
func (p *CoverageProfiler) MarkFile(file string, lines []int) \{\
    if !p.enabled \{\
        return\
    \}\
    \
    p.mu.Lock()\
    defer p.mu.Unlock()\
    \
    if _, ok := p.total[file]; !ok \{\
        p.total[file] = make(map[int]bool)\
        p.covered[file] = make(map[int]bool)\
    \}\
    \
    for _, line := range lines \{\
        p.total[file][line] = true\
    \}\
\}\
\
func (p *CoverageProfiler) Report() *CoverageReport \{\
    p.mu.RLock()\
    defer p.mu.RUnlock()\
    \
    report := &CoverageReport\{\
        Files: make([]FileCoverage, 0),\
    \}\
    \
    for file, totalLines := range p.total \{\
        coveredLines := p.covered[file]\
        \
        covered := 0\
        for line := range totalLines \{\
            if coveredLines[line] \{\
                covered++\
            \}\
        \}\
        \
        percentage := float64(covered) / float64(len(totalLines)) * 100\
        \
        report.Files = append(report.Files, FileCoverage\{\
            File:        file,\
            TotalLines:  len(totalLines),\
            CoveredLines: covered,\
            Lines:       coveredLines,\
            Percentage:  percentage,\
        \})\
        \
        report.TotalLines += len(totalLines)\
        report.CoveredLines += covered\
    \}\
    \
    if report.TotalLines > 0 \{\
        report.Percentage = float64(report.CoveredLines) / float64(report.TotalLines) * 100\
    \}\
    \
    // Sort files by coverage percentage\
    sort.Slice(report.Files, func(i, j int) bool \{\
        return report.Files[i].Percentage < report.Files[j].Percentage\
    \})\
    \
    return report\
\}\
\
func (p *CoverageProfiler) Reset() \{\
    p.mu.Lock()\
    defer p.mu.Unlock()\
    \
    p.covered = make(map[string]map[int]bool)\
    p.total = make(map[string]map[int]bool)\
\}\
\
func (p *CoverageProfiler) Enable() \{\
    p.enabled = true\
\}\
\
func (p *CoverageProfiler) Disable() \{\
    p.enabled = false\
\}\
\
func (report *CoverageReport) String() string \{\
    output := fmt.Sprintf("Coverage Report\\n")\
    output += fmt.Sprintf("Total Lines: %d\\n", report.TotalLines)\
    output += fmt.Sprintf("Covered Lines: %d\\n", report.CoveredLines)\
    output += fmt.Sprintf("Coverage: %.2f%%\\n\\n", report.Percentage)\
    \
    output += "File Coverage (worst first):\\n"\
    for _, file := range report.Files \{\
        output += fmt.Sprintf("  %s: %.2f%% (%d/%d)\\n", \
            file.File, file.Percentage, file.CoveredLines, file.TotalLines)\
        \
        // Show uncovered lines\
        uncovered := []int\{\}\
        for line := range file.Lines \{\
            if !file.Lines[line] \{\
                uncovered = append(uncovered, line)\
            \}\
        \}\
        \
        if len(uncovered) > 0 && len(uncovered) <= 10 \{\
            output += fmt.Sprintf("    Uncovered lines: %v\\n", uncovered)\
        \} else if len(uncovered) > 10 \{\
            output += fmt.Sprintf("    Uncovered lines: %v... (%d total)\\n", uncovered[:10], len(uncovered))\
        \}\
    \}\
    \
    return output\
\}\
\
// HTML report generation\
func (report *CoverageReport) ToHTML() string \{\
    html := `<!DOCTYPE html>\
<html>\
<head>\
    <title>Coverage Report</title>\
    <style>\
        body \{ font-family: monospace; margin: 20px; \}\
        .summary \{ background: #f0f0f0; padding: 10px; margin-bottom: 20px; \}\
        .file \{ margin-bottom: 20px; border: 1px solid #ddd; \}\
        .file-header \{ background: #4CAF50; color: white; padding: 10px; \}\
        .file-header.low \{ background: #f44336; \}\
        .file-header.medium \{ background: #ff9800; \}\
        .line \{ font-family: monospace; padding: 2px 5px; \}\
        .covered \{ background: #d4edda; \}\
        .uncovered \{ background: #f8d7da; \}\
        .line-number \{ display: inline-block; width: 50px; text-align: right; margin-right: 10px; color: #999; \}\
        .line-code \{ display: inline; \}\
    </style>\
</head>\
<body>\
    <div class="summary">\
        <h1>Coverage Report</h1>\
        <p>Total Lines: %d</p>\
        <p>Covered Lines: %d</p>\
        <p>Coverage: <strong>%.2f%%</strong></p>\
    </div>`\
    \
    html = fmt.Sprintf(html, report.TotalLines, report.CoveredLines, report.Percentage)\
    \
    for _, file := range report.Files \{\
        cssClass := "file-header"\
        if file.Percentage < 50 \{\
            cssClass += " low"\
        \} else if file.Percentage < 80 \{\
            cssClass += " medium"\
        \}\
        \
        html += fmt.Sprintf(`\
    <div class="file">\
        <div class="%s">\
            <strong>%s</strong> - %.2f%% (%d/%d lines covered)\
        </div>\
        <div class="file-content">\
`, cssClass, file.File, file.Percentage, file.CoveredLines, file.TotalLines)\
        \
        // Generate line-by-line coverage (would need source code)\
        \
        html += `        </div>\
    </div>`\
    \}\
    \
    html += `</body></html>`\
    return html\
\}\
```\
