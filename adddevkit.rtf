func CompileRustModule(sourcePath string) (*RustModule, error) \{\
    // Create temporary directory\
    tmpDir, err := os.MkdirTemp("", "nvs_rust_*")\
    if err != nil \{\
        return nil, err\
    \}\
    \
    // Copy source or create Cargo.toml\
    cargoToml := `[package]\
name = "nvs_module"\
version = "0.1.0"\
edition = "2021"\
\
[lib]\
crate-type = ["cdylib"]\
\
[dependencies]\
`\
    \
    if err := os.WriteFile(filepath.Join(tmpDir, "Cargo.toml"), []byte(cargoToml), 0644); err != nil \{\
        return nil, err\
    \}\
    \
    // Compile\
    cmd := exec.Command("cargo", "build", "--release")\
    cmd.Dir = tmpDir\
    if err := cmd.Run(); err != nil \{\
        return nil, fmt.Errorf("rust compilation failed: %v", err)\
    \}\
    \
    // Load library\
    libPath := filepath.Join(tmpDir, "target", "release", "libnvs_module.so")\
    lib, err := LoadLibrary(libPath)\
    if err != nil \{\
        return nil, err\
    \}\
    \
    return &RustModule\{\
        path:    tmpDir,\
        libPath: libPath,\
        lib:     lib,\
    \}, nil\
\}\
