func init() \{\
    rootCmd.AddCommand(initCmd, installCmd, updateCmd, publishCmd, \
                       runScriptCmd, listCmd, outdatedCmd, cacheCmd)\
\}\
\
func installFromManifest() \{\
    pkg := loadPackageManifest()\
    lockFile := loadLockFile()\
    \
    fmt.Printf("Installing dependencies for %s...\\n", pkg.Name)\
    \
    for name, version := range pkg.Dependencies \{\
        if _, ok := lockFile.Packages[name]; !ok \{\
            installPackageVersion(name, version)\
        \}\
    \}\
    \
    saveLockFile(lockFile)\
\}\
\
func installPackage(name string) \{\
    installPackageVersion(name, "latest")\
\}\
\
func installPackageVersion(name, version string) \{\
    // Parse package name (supports GitHub, local path, registry)\
    var repoURL string\
    var pkgVersion string\
    \
    if strings.Contains(name, "/") \{\
        // GitHub package\
        repoURL = "https://github.com/" + name + ".git"\
        pkgVersion = version\
    \} else if strings.HasPrefix(name, "file:") \{\
        // Local path\
        localPath := strings.TrimPrefix(name, "file:")\
        targetDir := filepath.Join("lib", filepath.Base(localPath))\
        if err := copyDir(localPath, targetDir); err != nil \{\
            fmt.Printf("Failed to copy %s: %v\\n", name, err)\
            return\
        \}\
        fmt.Printf("Installed %s\\n", name)\
        return\
    \} else \{\
        // Registry package\
        repoURL = getRegistryURL(name)\
        pkgVersion = version\
    \}\
    \
    targetDir := filepath.Join("lib", name)\
    \
    if _, err := os.Stat(targetDir); os.IsNotExist(err) \{\
        cmd := exec.Command("git", "clone", repoURL, targetDir)\
        if err := cmd.Run(); err != nil \{\
            fmt.Printf("Failed to clone %s: %v\\n", name, err)\
            return\
        \}\
        \
        if pkgVersion != "latest" && pkgVersion != "" \{\
            cmd = exec.Command("git", "-C", targetDir, "checkout", pkgVersion)\
            cmd.Run()\
        \}\
        \
        fmt.Printf("Installed %s@%s\\n", name, pkgVersion)\
    \} else \{\
        fmt.Printf("%s already installed\\n", name)\
    \}\
    \
    // Update lock file\
    lockFile := loadLockFile()\
    lockFile.Packages[name] = pkgVersion\
    saveLockFile(lockFile)\
\}\
\
func updatePackage(name string) \{\
    targetDir := filepath.Join("lib", name)\
    if _, err := os.Stat(targetDir); err == nil \{\
        cmd := exec.Command("git", "-C", targetDir, "pull")\
        if err := cmd.Run(); err != nil \{\
            fmt.Printf("Failed to update %s: %v\\n", name, err)\
            return\
        \}\
        fmt.Printf("Updated %s\\n", name)\
    \}\
\}\
\
func getLatestVersion(name string) string \{\
    // Query registry for latest version\
    url := fmt.Sprintf("https://registry.navescript.org/packages/%s/latest", name)\
    resp, err := http.Get(url)\
    if err != nil \{\
        return "unknown"\
    \}\
    defer resp.Body.Close()\
    \
    var result map[string]interface\{\}\
    json.NewDecoder(resp.Body).Decode(&result)\
    \
    if version, ok := result["version"].(string); ok \{\
        return version\
    \}\
    return "unknown"\
\}\
\
func getRegistryURL(name string) string \{\
    return fmt.Sprintf("https://github.com/navescript/%s.git", name)\
\}\
\
func loadPackageManifest() *Package \{\
    data, err := os.ReadFile("package.json")\
    if err != nil \{\
        fmt.Printf("Error: package.json not found. Run 'nvm init' first.\\n")\
        os.Exit(1)\
    \}\
    \
    var pkg Package\
    json.Unmarshal(data, &pkg)\
    return &pkg\
\}\
\
func loadLockFile() *LockFile \{\
    data, err := os.ReadFile("nvm.lock")\
    if err != nil \{\
        return &LockFile\{\
            Version:   1,\
            Packages:  make(map[string]string),\
            Integrity: make(map[string]string),\
        \}\
    \}\
    \
    var lock LockFile\
    json.Unmarshal(data, &lock)\
    return &lock\
\}\
\
func saveLockFile(lock *LockFile) \{\
    data, _ := json.MarshalIndent(lock, "", "  ")\
    os.WriteFile("nvm.lock", data, 0644)\
\}\
\
func getCurrentDir() string \{\
    dir, _ := os.Getwd()\
    return dir\
\}\
\
func getHomeDir() string \{\
    home, _ := os.UserHomeDir()\
    return home\
\}\
\
func copyDir(src, dst string) error \{\
    return filepath.Walk(src, func(path string, info os.FileInfo, err error) error \{\
        if err != nil \{\
            return err\
        \}\
        \
        relPath, _ := filepath.Rel(src, path)\
        targetPath := filepath.Join(dst, relPath)\
        \
        if info.IsDir() \{\
            return os.MkdirAll(targetPath, info.Mode())\
        \}\
        \
        data, err := os.ReadFile(path)\
        if err != nil \{\
            return err\
        \}\
        return os.WriteFile(targetPath, data, info.Mode())\
    \})\
\}\
\
func main() \{\
    rootCmd.Execute()\
\}\
