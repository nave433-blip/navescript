type SQLConnection struct \{\
    DB   *sql.DB\
    Type string\
\}\
\
var sqlConnections = make(map[string]*SQLConnection)\
var sqlMu sync.RWMutex\
\
var SQLModule = map[string]interface\{\}\{\
    "connect":    sqlConnect,\
    "close":      sqlClose,\
    "query":      sqlQuery,\
    "exec":       sqlExec,\
    "prepare":    sqlPrepare,\
    "begin":      sqlBegin,\
    "commit":     sqlCommit,\
    "rollback":   sqlRollback,\
    "insert":     sqlInsert,\
    "update":     sqlUpdate,\
    "delete":     sqlDelete,\
    "select":     sqlSelect,\
\}\
\
func sqlConnect(driver, dsn, name string) (map[string]interface\{\}, error) \{\
    db, err := sql.Open(driver, dsn)\
    if err != nil \{\
        return nil, err\
    \}\
    \
    if err := db.Ping(); err != nil \{\
        return nil, err\
    \}\
    \
    conn := &SQLConnection\{\
        DB:   db,\
        Type: driver,\
    \}\
    \
    sqlMu.Lock()\
    sqlConnections[name] = conn\
    sqlMu.Unlock()\
    \
    return map[string]interface\{\}\{\
        "name":   name,\
        "driver": driver,\
    \}, nil\
\}\
\
func sqlClose(name string) error \{\
    sqlMu.Lock()\
    defer sqlMu.Unlock()\
    \
    if conn, ok := sqlConnections[name]; ok \{\
        err := conn.DB.Close()\
        delete(sqlConnections, name)\
        return err\
    \}\
    return fmt.Errorf("connection not found: %s", name)\
\}\
\
func sqlQuery(name, query string, args []interface\{\}) ([]map[string]interface\{\}, error) \{\
    conn := getConnection(name)\
    if conn == nil \{\
        return nil, fmt.Errorf("connection not found: %s", name)\
    \}\
    \
    rows, err := conn.DB.Query(query, args...)\
    if err != nil \{\
        return nil, err\
    \}\
    defer rows.Close()\
    \
    columns, err := rows.Columns()\
    if err != nil \{\
        return nil, err\
    \}\
    \
    results := []map[string]interface\{\}\{\}\
    \
    for rows.Next() \{\
        values := make([]interface\{\}, len(columns))\
        valuePtrs := make([]interface\{\}, len(columns))\
        for i := range values \{\
            valuePtrs[i] = &values[i]\
        \}\
        \
        if err := rows.Scan(valuePtrs...); err != nil \{\
            return nil, err\
        \}\
        \
        row := make(map[string]interface\{\})\
        for i, col := range columns \{\
            val := values[i]\
            if b, ok := val.([]byte); ok \{\
                row[col] = string(b)\
            \} else \{\
                row[col] = val\
            \}\
        \}\
        results = append(results, row)\
    \}\
    \
    return results, nil\
\}\
\
func sqlExec(name, query string, args []interface\{\}) (int64, error) \{\
    conn := getConnection(name)\
    if conn == nil \{\
        return 0, fmt.Errorf("connection not found: %s", name)\
    \}\
    \
    result, err := conn.DB.Exec(query, args...)\
    if err != nil \{\
        return 0, err\
    \}\
    \
    return result.RowsAffected()\
