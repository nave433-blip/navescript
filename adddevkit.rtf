### **`internal/wasm/compiler.go`**\
```go\
package wasm\
\
import (\
    "bytes"\
    "encoding/binary"\
    "fmt"\
    \
    "github.com/navescript/nvs/internal/ast"\
    "github.com/navescript/nvs/internal/compiler"\
)\
\
type WASMCompiler struct \{\
    module      *WASMModule\
    funcIndex   int\
    localIndex  int\
    functions   map[string]int\
    imports     []WASMImport\
    exports     []WASMExport\
    dataSegments []WASMDataSegment\
\}\
\
type WASMModule struct \{\
    Magic   uint32\
    Version uint32\
    Sections []WASMSection\
\}\
\
type WASMSection struct \{\
    ID   byte\
    Data []byte\
\}\
\
type WASMImport struct \{\
    Module string\
    Name   string\
    Type   ImportType\
\}\
\
type ImportType struct \{\
    Kind      byte\
    TypeIndex uint32\
\}\
\
type WASMExport struct \{\
    Name  string\
    Kind  byte\
    Index uint32\
\}\
\
type WASMDataSegment struct \{\
    Index    uint32\
    Offset   uint32\
    Data     []byte\
\}\
\
func NewWASMCompiler() *WASMCompiler \{\
    return &WASMCompiler\{\
        module:    &WASMModule\{Magic: 0x6D736100, Version: 0x1\},\
        functions: make(map[string]int),\
    \}\
\}\
\
func (c *WASMCompiler) Compile(program *ast.Program) ([]byte, error) \{\
    // Generate type section\
    typeSection := c.generateTypeSection()\
    c.module.Sections = append(c.module.Sections, WASMSection\{ID: 1, Data: typeSection\})\
    \
    // Generate import section\
    importSection := c.generateImportSection()\
    c.module.Sections = append(c.module.Sections, WASMSection\{ID: 2, Data: importSection\})\
    \
    // Generate function section\
    funcSection := c.generateFunctionSection()\
    c.module.Sections = append(c.module.Sections, WASMSection\{ID: 3, Data: funcSection\})\
    \
    // Generate export section\
    exportSection := c.generateExportSection()\
    c.module.Sections = append(c.module.Sections, WASMSection\{ID: 7, Data: exportSection\})\
    \
    // Generate code section\
    codeSection, err := c.generateCodeSection(program)\
    if err != nil \{\
        return nil, err\
    \}\
    c.module.Sections = append(c.module.Sections, WASMSection\{ID: 10, Data: codeSection\})\
    \
    // Generate data section\
    dataSection := c.generateDataSection()\
    c.module.Sections = append(c.module.Sections, WASMSection\{ID: 11, Data: dataSection\})\
    \
    // Encode module\
    return c.encodeModule(), nil\
\}\
\
func (c *WASMCompiler) generateTypeSection() []byte \{\
    buf := bytes.NewBuffer(nil)\
    \
    // Number of types\
    writeULEB128(buf, 1)\
    \
    // Function type\
    buf.WriteByte(0x60) // func type\
    \
    // Parameters\
    writeULEB128(buf, 0) // no params\
    \
    // Results\
    writeULEB128(buf, 1) // one result\
    buf.WriteByte(0x7F)  // i32\
    \
    return buf.Bytes()\
\}\
\
func (c *WASMCompiler) generateImportSection() []byte \{\
    buf := bytes.NewBuffer(nil)\
    \
    // Number of imports\
    writeULEB128(buf, 2)\
    \
    // Import 1: console.log\
    writeString(buf, "env")\
    writeString(buf, "log")\
    buf.WriteByte(0x00) // func import\
    writeULEB128(buf, 0) // type index\
    \
    // Import 2: memory\
    writeString(buf, "env")\
    writeString(buf, "memory")\
    buf.WriteByte(0x02) // memory import\
    writeULEB128(buf, 0) // limits\
    writeULEB128(buf, 1) // min pages (64KB)\
    \
    return buf.Bytes()\
\}\
\
func (c *WASMCompiler) generateFunctionSection() []byte \{\
    buf := bytes.NewBuffer(nil)\
    \
    // Number of functions\
    writeULEB128(buf, 1)\
    \
    // Function type index\
    writeULEB128(buf, 0)\
    \
    return buf.Bytes()\
\}\
\
func (c *WASMCompiler) generateExportSection() []byte \{\
    buf := bytes.NewBuffer(nil)\
    \
    // Number of exports\
    writeULEB128(buf, 1)\
    \
    // Export main\
    writeString(buf, "main")\
    buf.WriteByte(0x00) // func export\
    writeULEB128(buf, 0) // function index\
    \
    return buf.Bytes()\
\}\
\
func (c *WASMCompiler) generateCodeSection(program *ast.Program) ([]byte, error) \{\
    buf := bytes.NewBuffer(nil)\
    \
    // Number of functions\
    writeULEB128(buf, 1)\
    \
    // Function body\
    bodyBuf := bytes.NewBuffer(nil)\
    \
    // Local declarations\
    writeULEB128(bodyBuf, 0) // no locals\
    \
    // Generate instructions from AST\
    if err := c.generateInstructions(bodyBuf, program); err != nil \{\
        return nil, err\
    \}\
    \
    // End instruction\
    bodyBuf.WriteByte(0x0B)\
    \
    // Write function body size\
    writeULEB128(buf, uint32(bodyBuf.Len()))\
    buf.Write(bodyBuf.Bytes())\
    \
    return buf.Bytes(), nil\
\}\
\
func (c *WASMCompiler) generateInstructions(buf *bytes.Buffer, node ast.Node) error \{\
    switch n := node.(type) \{\
    case *ast.Program:\
        for _, stmt := range n.Statements \{\
            if err := c.generateInstructions(buf, stmt); err != nil \{\
                return err\
            \}\
        \}\
        \
    case *ast.ExpressionStatement:\
        if err := c.generateInstructions(buf, n.Expression); err != nil \{\
            return err\
        \}\
        buf.WriteByte(0x1A) // drop\
        \
    case *ast.IntegerLiteral:\
        writeLEB128(buf, n.Value)\
        buf.WriteByte(0x41) // i32.const\
        \
    case *ast.StringLiteral:\
        // Store string in data segment\
        idx := len(c.dataSegments)\
        c.dataSegments = append(c.dataSegments, WASMDataSegment\{\
            Index:  0,\
            Offset: uint32(len(c.dataSegments) * 1024),\
            Data:   []byte(n.Value),\
        \})\
        writeULEB128(buf, uint32(idx))\
        buf.WriteByte(0x41) // i32.const\
        \
    case *ast.InfixExpression:\
        if err := c.generateInstructions(buf, n.Left); err != nil \{\
            return err\
        \}\
        if err := c.generateInstructions(buf, n.Right); err != nil \{\
            return err\
        \}\
        \
        switch n.Operator \{\
        case "+":\
            buf.WriteByte(0x6A) // i32.add\
        case "-":\
            buf.WriteByte(0x6B) // i32.sub\
        case "*":\
            buf.WriteByte(0x6C) // i32.mul\
        case "/":\
            buf.WriteByte(0x6D) // i32.div_s\
        \}\
        \
    case *ast.CallExpression:\
        if err := c.generateInstructions(buf, n.Function); err != nil \{\
            return err\
        \}\
        for _, arg := range n.Arguments \{\
            if err := c.generateInstructions(buf, arg); err != nil \{\
                return err\
            \}\
        \}\
        buf.WriteByte(0x10) // call\
        writeULEB128(buf, 0) // function index\
        \
    default:\
        return fmt.Errorf("unsupported node type: %T", n)\
    \}\
    \
    return nil\
\}\
\
func (c *WASMCompiler) generateDataSection() []byte \{\
    buf := bytes.NewBuffer(nil)\
    \
    // Number of data segments\
    writeULEB128(buf, uint32(len(c.dataSegments)))\
    \
    for _, seg := range c.dataSegments \{\
        buf.WriteByte(0x00) // memory index\
        writeULEB128(buf, seg.Offset)\
        writeULEB128(buf, uint32(len(seg.Data)))\
        buf.Write(seg.Data)\
    \}\
    \
    return buf.Bytes()\
\}\
\
func (c *WASMCompiler) encodeModule() []byte \{\
    buf := bytes.NewBuffer(nil)\
    \
    // Magic number\
    binary.Write(buf, binary.LittleEndian, c.module.Magic)\
    binary.Write(buf, binary.LittleEndian, c.module.Version)\
    \
    // Sections\
    for _, section := range c.module.Sections \{\
        buf.WriteByte(section.ID)\
        writeULEB128(buf, uint32(len(section.Data)))\
        buf.Write(section.Data)\
    \}\
    \
    return buf.Bytes()\
\}\
\
// Helper functions\
func writeULEB128(buf *bytes.Buffer, value uint32) \{\
    for \{\
        b := byte(value & 0x7F)\
        value >>= 7\
        if value != 0 \{\
            b |= 0x80\
        \}\
        buf.WriteByte(b)\
        if value == 0 \{\
            break\
        \}\
    \}\
\}\
\
func writeLEB128(buf *bytes.Buffer, value int64) \{\
    for \{\
        b := byte(value & 0x7F)\
        value >>= 7\
        if (value != 0 && value != -1) || (value == -1 && (b&0x40) == 0) \{\
            b |= 0x80\
        \}\
        buf.WriteByte(b)\
        if (b & 0x80) == 0 \{\
            break\
        \}\
    \}\
\}\
\
func writeString(buf *bytes.Buffer, s string) \{\
    writeULEB128(buf, uint32(len(s)))\
    buf.WriteString(s)\
\}\
