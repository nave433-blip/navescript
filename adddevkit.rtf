package compiler\
\
func MakeInstruction(op Opcode, operands ...int) []byte \{\
    switch op \{\
    case OpConstant, OpSetGlobal, OpGetGlobal, OpSetLocal, OpGetLocal, \
         OpClosure, OpCall, OpJump, OpJumpNotTruthy:\
        return append([]byte\{byte(op)\}, encodeUint16(uint16(operands[0]))...)\
    default:\
        return []byte\{byte(op)\}\
    \}\
\}\
\
func encodeUint16(value uint16) []byte \{\
    return []byte\{byte(value >> 8), byte(value & 0xFF)\}\
\}\
\
func ReadUint16(ins []byte) uint16 \{\
    return uint16(ins[0])<<8 | uint16(ins[1])\
\}\
\
type CompiledFunction struct \{\
    Instructions  []byte\
    NumLocals     int\
    NumParameters int\
\}\
