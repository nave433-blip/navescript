### **`internal/ffi/cffi.go`**\
```go\
package ffi\
\
import (\
    "fmt"\
    "reflect"\
    "unsafe"\
)\
\
/*\
#include <stdlib.h>\
#include <dlfcn.h>\
\
typedef void* (*void_func)();\
typedef int (*int_func)();\
typedef double (*double_func)();\
typedef char* (*string_func)();\
\
void* load_lib(const char* path) \{\
    return dlopen(path, RTLD_LAZY);\
\}\
\
void* get_sym(void* handle, const char* name) \{\
    return dlsym(handle, name);\
\}\
\
void close_lib(void* handle) \{\
    dlclose(handle);\
\}\
*/\
import "C"\
\
type Library struct \{\
    handle unsafe.Pointer\
    name   string\
    funcs  map[string]unsafe.Pointer\
\}\
\
type CFunc struct \{\
    Name     string\
    RetType  reflect.Type\
    ArgTypes []reflect.Type\
    Ptr      unsafe.Pointer\
\}\
\
var loadedLibs = make(map[string]*Library)\
\
func LoadLibrary(path string) (*Library, error) \{\
    if lib, ok := loadedLibs[path]; ok \{\
        return lib, nil\
    \}\
    \
    cPath := C.CString(path)\
    defer C.free(unsafe.Pointer(cPath))\
    \
    handle := C.load_lib(cPath)\
    if handle == nil \{\
        return nil, fmt.Errorf("failed to load library: %s", path)\
    \}\
    \
    lib := &Library\{\
        handle: handle,\
        name:   path,\
        funcs:  make(map[string]unsafe.Pointer),\
    \}\
    \
    loadedLibs[path] = lib\
    return lib, nil\
\}\
\
func (lib *Library) GetFunc(name string, retType reflect.Type, argTypes ...reflect.Type) (*CFunc, error) \{\
    if ptr, ok := lib.funcs[name]; ok \{\
        return &CFunc\{Name: name, RetType: retType, ArgTypes: argTypes, Ptr: ptr\}, nil\
    \}\
    \
    cName := C.CString(name)\
    defer C.free(unsafe.Pointer(cName))\
    \
    ptr := C.get_sym(lib.handle, cName)\
    if ptr == nil \{\
        return nil, fmt.Errorf("symbol not found: %s", name)\
    \}\
    \
    lib.funcs[name] = ptr\
    \
    return &CFunc\{\
        Name:     name,\
        RetType:  retType,\
        ArgTypes: argTypes,\
        Ptr:      ptr,\
    \}, nil\
\}\
\
func (lib *Library) Close() error \{\
    if lib.handle != nil \{\
        C.close_lib(lib.handle)\
        lib.handle = nil\
        delete(loadedLibs, lib.name)\
    \}\
    return nil\
\}\
\
func CallCFunc(fn *CFunc, args ...interface\{\}) (interface\{\}, error) \{\
    if len(args) != len(fn.ArgTypes) \{\
        return nil, fmt.Errorf("argument count mismatch: expected %d, got %d", len(fn.ArgTypes), len(args))\
    \}\
    \
    // Prepare arguments\
    cArgs := make([]unsafe.Pointer, len(args))\
    for i, arg := range args \{\
        cArgs[i] = convertToC(arg, fn.ArgTypes[i])\
    \}\
    \
    // Call function based on return type\
    switch fn.RetType.Kind() \{\
    case reflect.Int:\
        fnPtr := (*C.int_func)(unsafe.Pointer(&fn.Ptr))\
        result := (*fnPtr)()\
        return int(result), nil\
        \
    case reflect.Int64:\
        fnPtr := (*func() int64)(unsafe.Pointer(&fn.Ptr))\
        return (*fnPtr)(), nil\
        \
    case reflect.Float64:\
        fnPtr := (*C.double_func)(unsafe.Pointer(&fn.Ptr))\
        result := (*fnPtr)()\
        return float64(result), nil\
        \
    case reflect.String:\
        fnPtr := (*C.string_func)(unsafe.Pointer(&fn.Ptr))\
        result := (*fnPtr)()\
        defer C.free(unsafe.Pointer(result))\
        return C.GoString(result), nil\
        \
    case reflect.Uintptr:\
        fnPtr := (*func() unsafe.Pointer)(unsafe.Pointer(&fn.Ptr))\
        return uintptr((*fnPtr)()), nil\
        \
    default:\
        fnPtr := (*C.void_func)(unsafe.Pointer(&fn.Ptr))\
        (*fnPtr)()\
        return nil, nil\
    \}\
\}\
\
func convertToC(arg interface\{\}, t reflect.Type) unsafe.Pointer \{\
    switch v := arg.(type) \{\
    case int:\
        return unsafe.Pointer(&v)\
    case int64:\
        return unsafe.Pointer(&v)\
    case float64:\
        return unsafe.Pointer(&v)\
    case string:\
        return unsafe.Pointer(C.CString(v))\
    case []byte:\
        return unsafe.Pointer(&v[0])\
    default:\
        return nil\
    \}\
\}\
