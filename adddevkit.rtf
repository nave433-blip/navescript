    resp, err := http.Get(url)\
    if err != nil \{\
        return nil, err\
    \}\
    defer resp.Body.Close()\
    \
    body, err := ioutil.ReadAll(resp.Body)\
    if err != nil \{\
        return nil, err\
    \}\
    \
    headers := make(map[string]string)\
    for k, v := range resp.Header \{\
        if len(v) > 0 \{\
            headers[k] = v[0]\
        \}\
    \}\
    \
    return map[string]interface\{\}\{\
        "status": resp.StatusCode,\
        "body":   string(body),\
        "headers": headers,\
    \}, nil\
\}\
