**`Makefile`** (Complete)\
```makefile\
.PHONY: build install clean test cross-compile docs release\
\
VERSION := $(shell git describe --tags --always --dirty 2>/dev/null || echo "dev")\
BUILD_DIR := bin\
RELEASE_DIR := release\
\
LDFLAGS := -ldflags "-X main.Version=$(VERSION) -s -w"\
\
# Build for current platform\
build:\
	@mkdir -p $(BUILD_DIR)\
	go build $(LDFLAGS) -o $(BUILD_DIR)/nvs ./cmd/nvs\
	go build $(LDFLAGS) -o $(BUILD_DIR)/nvm ./cmd/nvm\
	go build $(LDFLAGS) -o $(BUILD_DIR)/nvs-debug ./cmd/nvs-debug\
	@echo "Build complete for $(VERSION)"\
\
# Cross-compile for all platforms\
cross-compile:\
	@mkdir -p $(RELEASE_DIR)\
	\
	# Linux (amd64)\
	GOOS=linux GOARCH=amd64 go build $(LDFLAGS) -o $(RELEASE_DIR)/nvs-linux-amd64 ./cmd/nvs\
	GOOS=linux GOARCH=amd64 go build $(LDFLAGS) -o $(RELEASE_DIR)/nvm-linux-amd64 ./cmd/nvm\
	GOOS=linux GOARCH=amd64 go build $(LDFLAGS) -o $(RELEASE_DIR)/nvs-debug-linux-amd64 ./cmd/nvs-debug\
	\
	# Linux (arm64)\
	GOOS=linux GOARCH=arm64 go build $(LDFLAGS) -o $(RELEASE_DIR)/nvs-linux-arm64 ./cmd/nvs\
	GOOS=linux GOARCH=arm64 go build $(LDFLAGS) -o $(RELEASE_DIR)/nvm-linux-arm64 ./cmd/nvm\
	GOOS=linux GOARCH=arm64 go build $(LDFLAGS) -o $(RELEASE_DIR)/nvs-debug-linux-arm64 ./cmd/nvs-debug\
	\
	# Windows (amd64)\
	GOOS=windows GOARCH=amd64 go build $(LDFLAGS) -o $(RELEASE_DIR)/nvs-windows-amd64.exe ./cmd/nvs\
	GOOS=windows GOARCH=amd64 go build $(LDFLAGS) -o $(RELEASE_DIR)/nvm-windows-amd64.exe ./cmd/nvm\
	GOOS=windows GOARCH=amd64 go build $(LDFLAGS) -o $(RELEASE_DIR)/nvs-debug-windows-amd64.exe ./cmd/nvs-debug\
	\
	# macOS (amd64)\
	GOOS=darwin GOARCH=amd64 go build $(LDFLAGS) -o $(RELEASE_DIR)/nvs-darwin-amd64 ./cmd/nvs\
	GOOS=darwin GOARCH=amd64 go build $(LDFLAGS) -o $(RELEASE_DIR)/nvm-darwin-amd64 ./cmd/nvm\
	GOOS=darwin GOARCH=amd64 go build $(LDFLAGS) -o $(RELEASE_DIR)/nvs-debug-darwin-amd64 ./cmd/nvs-debug\
	\
	# macOS (arm64)\
	GOOS=darwin GOARCH=arm64 go build $(LDFLAGS) -o $(RELEASE_DIR)/nvs-darwin-arm64 ./cmd/nvs\
	GOOS=darwin GOARCH=arm64 go build $(LDFLAGS) -o $(RELEASE_DIR)/nvm-darwin-arm64 ./cmd/nvm\
	GOOS=darwin GOARCH=arm64 go build $(LDFLAGS) -o $(RELEASE_DIR)/nvs-debug-darwin-arm64 ./cmd/nvs-debug\
	\
	@echo "Cross-compilation complete"\
\
# Install locally\
install: build\
	@cp $(BUILD_DIR)/nvs /usr/local/bin/\
	@cp $(BUILD_DIR)/nvm /usr/local/bin/\
	@cp $(BUILD_DIR)/nvs-debug /usr/local/bin/\
	@echo "Installed to /usr/local/bin"\
\
# Run tests\
test:\
	go test ./...\
	@echo "Running language tests..."\
	@./$(BUILD_DIR)/nvs run test/test_suite.nvs\
\
# Generate documentation\
docs:\
	@mkdir -p docs/html\
	@./$(BUILD_DIR)/nvs doc ./std -o docs/html\
	@echo "Documentation generated in docs/html/"\
\
# Create release packages\
release: cross-compile\
	@mkdir -p $(RELEASE_DIR)/packages\
	\
	# Create tarballs\
	cd $(RELEASE_DIR) && tar -czf packages/navescript-$(VERSION)-linux-amd64.tar.gz nvs-linux-amd64 nvm-linux-amd64 nvs-debug-linux-amd64\
	cd $(RELEASE_DIR) && tar -czf packages/navescript-$(VERSION)-linux-arm64.tar.gz nvs-linux-arm64 nvm-linux-arm64 nvs-debug-linux-arm64\
	cd $(RELEASE_DIR) && tar -czf packages/navescript-$(VERSION)-darwin-amd64.tar.gz nvs-darwin-amd64 nvm-darwin-amd64 nvs-debug-darwin-amd64\
	cd $(RELEASE_DIR) && tar -czf packages/navescript-$(VERSION)-darwin-arm64.tar.gz nvs-darwin-arm64 nvm-darwin-arm64 nvs-debug-darwin-arm64\
	\
	# Create zip for Windows\
	cd $(RELEASE_DIR) && zip packages/navescript-$(VERSION)-windows-amd64.zip nvs-windows-amd64.exe nvm-windows-amd64.exe nvs-debug-windows-amd64.exe\
	\
	@echo "Release packages created in $(RELEASE_DIR)/packages/"\
\
# Clean build artifacts\
clean:\
	@rm -rf $(BUILD_DIR) $(RELEASE_DIR)\
	@echo "Cleaned"\
\
# Run REPL\
repl: build\
	@./$(BUILD_DIR)/nvs repl\
\
# Format code\
fmt:\
	go fmt ./...\
	@./$(BUILD_DIR)/nvs fmt ./std/*.nvs\
\
# Lint code\
lint:\
	golangci-lint run\
	@echo "Linting complete"\
\
# Install development dependencies\
dev-deps:\
	go install github.com/golangci/golangci-lint/cmd/golangci-lint@latest\
	go mod download\
\
# Show version\
version:\
	@echo "NaveScript version $(VERSION)"\
\
# Help\
help:\
	@echo "Available targets:"\
	@echo "  build         - Build for current platform"\
	@echo "  cross-compile - Build for all platforms"\
	@echo "  install       - Install to /usr/local/bin"\
	@echo "  test          - Run tests"\
	@echo "  docs          - Generate documentation"\
	@echo "  release       - Create release packages"\
	@echo "  clean         - Remove build artifacts"\
	@echo "  repl          - Start interactive REPL"\
	@echo "  fmt           - Format code"\
	@echo "  lint          - Lint code"\
	@echo "  version       - Show version"\
```\
