```go\
package stdlib\
\
import (\
    "regexp"\
    "sync"\
)\
\
type RegexModule struct \{\
    cache map[string]*regexp.Regexp\
    mu    sync.RWMutex\
\}\
\
var regexInstance = &RegexModule\{\
    cache: make(map[string]*regexp.Regexp),\
\}\
\
var RegexModuleMap = map[string]interface\{\}\{\
    "compile":    regexCompile,\
    "match":      regexMatch,\
    "find":       regexFind,\
    "find_all":   regexFindAll,\
    "replace":    regexReplace,\
    "split":      regexSplit,\
    "escape":     regexEscape,\
    "must_compile": regexMustCompile,\
\}\
\
func regexCompile(pattern string) (map[string]interface\{\}, error) \{\
    re, err := regexp.Compile(pattern)\
    if err != nil \{\
        return nil, err\
    \}\
    \
    regexInstance.mu.Lock()\
    regexInstance.cache[pattern] = re\
    regexInstance.mu.Unlock()\
    \
    return map[string]interface\{\}\{\
        "pattern": pattern,\
        "handle":  re,\
    \}, nil\
\}\
\
func regexMustCompile(pattern string) map[string]interface\{\} \{\
    result, _ := regexCompile(pattern)\
    return result\
\}\
\
func getRegex(pattern string) *regexp.Regexp \{\
    regexInstance.mu.RLock()\
    defer regexInstance.mu.RUnlock()\
    return regexInstance.cache[pattern]\
\}\
\
func regexMatch(pattern, text string) bool \{\
    re := getRegex(pattern)\
    if re == nil \{\
        re, _ = regexp.Compile(pattern)\
    \}\
    return re.MatchString(text)\
\}\
\
func regexFind(pattern, text string) string \{\
    re := getRegex(pattern)\
    if re == nil \{\
        re, _ = regexp.Compile(pattern)\
    \}\
    return re.FindString(text)\
\}\
\
func regexFindAll(pattern, text string, n int) []string \{\
    re := getRegex(pattern)\
    if re == nil \{\
        re, _ = regexp.Compile(pattern)\
    \}\
    if n == 0 \{\
        n = -1\
    \}\
    return re.FindAllString(text, n)\
\}\
\
func regexReplace(pattern, text, replace string) string \{\
    re := getRegex(pattern)\
    if re == nil \{\
        re, _ = regexp.Compile(pattern)\
    \}\
    return re.ReplaceAllString(text, replace)\
\}\
\
func regexSplit(pattern, text string, n int) []string \{\
    re := getRegex(pattern)\
    if re == nil \{\
        re, _ = regexp.Compile(pattern)\
    \}\
    if n == 0 \{\
        n = -1\
    \}\
    return re.Split(text, n)\
\}\
\
func regexEscape(text string) string \{\
    return regexp.QuoteMeta(text)\
\}\
