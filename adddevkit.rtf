var CSVModule = map[string]interface\{\}\{\
    "parse":      csvParse,\
    "encode":     csvEncode,\
    "read_file":  csvReadFile,\
    "write_file": csvWriteFile,\
    "parse_row":  csvParseRow,\
\}\
\
func csvParse(data string, delimiter rune) ([][]string, error) \{\
    reader := csv.NewReader(strings.NewReader(data))\
    reader.Comma = delimiter\
    reader.FieldsPerRecord = -1\
    reader.TrimLeadingSpace = true\
    \
    return reader.ReadAll()\
\}\
\
func csvEncode(rows [][]string, delimiter rune) (string, error) \{\
    var buf strings.Builder\
    writer := csv.NewWriter(&buf)\
    writer.Comma = delimiter\
    \
    for _, row := range rows \{\
        if err := writer.Write(row); err != nil \{\
            return "", err\
        \}\
    \}\
    writer.Flush()\
    \
    if err := writer.Error(); err != nil \{\
        return "", err\
    \}\
    \
    return buf.String(), nil\
\}\
\
func csvReadFile(filename string, delimiter rune) ([][]string, error) \{\
    data, err := readFile(filename)\
    if err != nil \{\
        return nil, err\
    \}\
    return csvParse(data, delimiter)\
\}\
\
func csvWriteFile(filename string, rows [][]string, delimiter rune) error \{\
    data, err := csvEncode(rows, delimiter)\
    if err != nil \{\
        return err\
    \}\
    return writeFile(filename, data)\
\}\
\
func csvParseRow(line string, delimiter rune) ([]string, error) \{\
    reader := csv.NewReader(strings.NewReader(line))\
    reader.Comma = delimiter\
    reader.FieldsPerRecord = -1\
    reader.TrimLeadingSpace = true\
    reader.ReuseRecord = true\
    \
    record, err := reader.Read()\
    if err == io.EOF \{\
        return []string\{\}, nil\
    \}\
    if err != nil \{\
        return nil, err\
    \}\
    return record, nil\
\}\
