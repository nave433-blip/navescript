// Native Navescript Core Standard Library
// This file implements core functionality in native Navescript code
// which will be compiled by the Nvs CLI.

module std.core;

pub fn println(msg: string) {
    // Native implementation calling into runtime
    ffi::call("console.log", [msg]);
}

pub fn panic(msg: string) {
    ffi::call("runtime.abort", [msg]);
}
