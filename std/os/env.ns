// Native Navescript OS Environment
module std.os.env;

pub fn get(key: string) -> string {
    return ffi::call("nasi.env.get", [key]);
}

pub fn set(key: string, value: string) {
    ffi::call("nasi.env.set", [key, value]);
}

pub fn all() -> Map<string, string> {
    return ffi::call("nasi.env.all", []);
}
