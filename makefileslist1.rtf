package concurrency\
\
import (\
	"runtime"\
	"sync"\
	"sync/atomic"\
	"time"\
)\
\
type GoroutineScheduler struct \{\
	goroutines   map[uint64]*Goroutine\
	queue        chan *Goroutine\
	workers      int\
	workStealing bool\
	running      bool\
	wg           sync.WaitGroup\
	nextID       uint64\
	mu           sync.RWMutex\
\}\
\
type Goroutine struct \{\
	ID     uint64\
	Func   func(...interface\{\}) interface\{\}\
	Args   []interface\{\}\
	Result chan interface\{\}\
	Status int32\
\}\
\
var globalScheduler *GoroutineScheduler\
var once sync.Once\
\
func GetScheduler() *GoroutineScheduler \{\
	once.Do(func() \{\
		globalScheduler = &GoroutineScheduler\{\
			goroutines:   make(map[uint64]*Goroutine),\
			queue:        make(chan *Goroutine, 10000),\
			workers:      runtime.NumCPU() * 4,\
			workStealing: true,\
			running:      true,\
		\}\
		globalScheduler.Start()\
	\})\
	return globalScheduler\
\}\
\
func (s *GoroutineScheduler) Start() \{\
	for i := 0; i < s.workers; i++ \{\
		s.wg.Add(1)\
		go s.worker()\
	\}\
\}\
\
func Go(fn func(...interface\{\}) interface\{\}, args ...interface\{\}) uint64 \{\
	scheduler := GetScheduler()\
	id := atomic.AddUint64(&scheduler.nextID, 1)\
	g := &Goroutine\{\
		ID:     id,\
		Func:   fn,\
		Args:   args,\
		Result: make(chan interface\{\}, 1),\
		Status: 0,\
	\}\
	scheduler.queue <- g\
	return id\
\}\
