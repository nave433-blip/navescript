        f, err := os.Create(output)\
        if err != nil \{\
            fmt.Printf("Error: %v\\n", err)\
            os.Exit(1)\
        \}\
        defer f.Close()\
        \
        pprof.StartCPUProfile(f)\
        time.Sleep(duration)\
        pprof.StopCPUProfile()\
        \
        fmt.Printf("CPU profile written to %s\\n", output)\
