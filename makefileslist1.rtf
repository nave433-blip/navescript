```go\
package engines\
\
import (\
	"bytes"\
	"context"\
	"fmt"\
	"os"\
	"time"\
\
	"github.com/wasmerio/wasmer-go/wasmer"\
)\
\
type WASMEngine struct\{\}\
\
func (e *WASMEngine) Name() string \{ return "wasm" \}\
\
func (e *WASMEngine) Execute(code string, args []string) (string, error) \{\
	// For .wat text or raw binary WASM\
	wasmBytes := []byte(code)\
\
	engine := wasmer.NewEngine()\
	store := wasmer.NewStore(engine)\
\
	module, err := wasmer.NewModule(store, wasmBytes)\
	if err != nil \{\
		return "", fmt.Errorf("failed to compile wasm: %v", err)\
	\}\
\
	importObject := wasmer.NewImportObject()\
	instance, err := wasmer.NewInstance(module, importObject)\
	if err != nil \{\
		return "", fmt.Errorf("failed to instantiate wasm: %v", err)\
	\}\
\
	// Try to call exported main function\
	if export, ok := instance.Exports.GetFunction("main"); ok \{\
		ctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\
		defer cancel()\
\
		result, err := export.Call(ctx)\
		if err != nil \{\
			return "", fmt.Errorf("wasm execution error: %v", err)\
		\}\
\
		return fmt.Sprintf("%v", result), nil\
	\}\
\
	return "", fmt.Errorf("no main function exported in wasm module")\
\}\
