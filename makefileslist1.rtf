### **`internal/stdlib/time.go`**\
```go\
package stdlib\
\
import "time"\
\
var TimeModule = map[string]interface\{\}\{\
    "now":          timeNow,\
    "sleep":        timeSleep,\
    "since":        timeSince,\
    "until":        timeUntil,\
    "format":       timeFormat,\
    "parse":        timeParse,\
    "unix":         timeUnix,\
    "unix_nano":    timeUnixNano,\
    "duration":     timeDuration,\
    "after":        timeAfter,\
    "ticker":       timeTicker,\
    "timer":        timeTimer,\
\}\
\
type TimeObj struct \{\
    t time.Time\
\}\
\
func timeNow() map[string]interface\{\} \{\
    return map[string]interface\{\}\{\
        "unix":      time.Now().Unix(),\
        "unix_nano": time.Now().UnixNano(),\
        "year":      time.Now().Year(),\
        "month":     int(time.Now().Month()),\
        "day":       time.Now().Day(),\
        "hour":      time.Now().Hour(),\
        "minute":    time.Now().Minute(),\
        "second":    time.Now().Second(),\
        "nanosecond": time.Now().Nanosecond(),\
        "weekday":   int(time.Now().Weekday()),\
        "year_day":  time.Now().YearDay(),\
    \}\
\}\
\
func timeSleep(duration int64) \{\
    time.Sleep(time.Duration(duration) * time.Millisecond)\
\}\
\
func timeSince(timestamp int64) int64 \{\
    return time.Now().Unix() - timestamp\
\}\
\
func timeUntil(timestamp int64) int64 \{\
    return timestamp - time.Now().Unix()\
\}\
\
func timeFormat(timestamp int64, layout string) string \{\
    return time.Unix(timestamp, 0).Format(layout)\
\}\
\
func timeParse(layout, value string) (int64, error) \{\
    t, err := time.Parse(layout, value)\
    if err != nil \{\
        return 0, err\
    \}\
    return t.Unix(), nil\
\}\
\
func timeUnix() int64 \{\
    return time.Now().Unix()\
\}\
\
func timeUnixNano() int64 \{\
    return time.Now().UnixNano()\
\}\
\
func timeDuration(start, end int64) int64 \{\
    return end - start\
\}\
\
func timeAfter(duration int64, callback func()) \{\
    go func() \{\
        time.Sleep(time.Duration(duration) * time.Millisecond)\
        callback()\
    \}()\
\}\
\
func timeTicker(duration int64, callback func()) func() \{\
    ticker := time.NewTicker(time.Duration(duration) * time.Millisecond)\
    stop := make(chan bool)\
    \
    go func() \{\
        for \{\
            select \{\
            case <-ticker.C:\
                callback()\
            case <-stop:\
                ticker.Stop()\
                return\
            \}\
        \}\
    \}()\
    \
    return func() \{\
        stop <- true\
    \}\
\}\
\
func timeTimer(duration int64, callback func()) func() \{\
    timer := time.NewTimer(time.Duration(duration) * time.Millisecond)\
    stop := make(chan bool)\
    \
    go func() \{\
        select \{\
        case <-timer.C:\
            callback()\
        case <-stop:\
            timer.Stop()\
        \}\
    \}()\
    \
    return func() \{\
        stop <- true\
    \}\
\}\
