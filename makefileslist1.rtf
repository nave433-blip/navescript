	buffer   []interface\{\}\
	size     int\
	sendCh   chan struct\{\}\
	recvCh   chan struct\{\}\
	mu       sync.Mutex\
	closed   bool\
	id       uint64\
\}\
\
var channelCounter uint64\
\
func NewChannel(name string, size int) *Channel \{\
	ch := &Channel\{\
		Name:   name,\
		buffer: make([]interface\{\}, 0, size),\
		size:   size,\
		id:     atomic.AddUint64(&channelCounter, 1),\
	\}\
	if size == 0 \{\
		ch.sendCh = make(chan struct\{\})\
		ch.recvCh = make(chan struct\{\})\
	\} else \{\
		ch.sendCh = make(chan struct\{\}, 1)\
		ch.recvCh = make(chan struct\{\}, 1)\
	\}\
	return ch\
\}\
\
func (ch *Channel) Send(value interface\{\}) bool \{\
	ch.mu.Lock()\
	defer ch.mu.Unlock()\
\
	if ch.closed \{\
		return false\
	\}\
\
	if ch.size > 0 && len(ch.buffer) < ch.size \{\
		ch.buffer = append(ch.buffer, value)\
		return true\
	\}\
\
	// Unbuffered or full channel logic (simplified)\
	return false\
\}\
\
func (ch *Channel) Receive() (interface\{\}, bool) \{\
	ch.mu.Lock()\
	defer ch.mu.Unlock()\
\
	if len(ch.buffer) > 0 \{\
		value := ch.buffer[0]\
		ch.buffer = ch.buffer[1:]\
		return value, true\
	\}\
\
	if ch.closed \{\
		return nil, false\
	\}\
	return nil, false\
\}\
\
